    g.AddText(offsetX + 85, offsetY + 132, HUE_WHITE_TEXT, '      *CHAMPION RAIL*');

    var leftBtn = offsetX + 25, leftText = offsetX + 60;
    var rightBtn = offsetX + 225, rightSet = offsetX + 210, rightText = offsetX + 260;
