    AddSmallSetButton(g, 7105, offsetX + 185, offsetY + 133, '65', 'Salva posizione Compagnone');
    g.AddText(offsetX + 205, offsetY + 130, 65, 'SAVE');

    g.AddText(offsetX + 35, offsetY + 165, HUE_LABEL_ON, 'DURABILITY');
