var GLOBAL_TEXT_Y_OFFSET = -2;

function DrawPanel(g, offsetX, offsetY, width, height) {
    // LIGHT: niente pannello pieno, cosi il menu resta trasparente.
}

function CalculateCenteredX(guiWidth, text, averageCharWidth) {
    return Math.floor((guiWidth - (text.length * averageCharWidth)) / 2);
}

function GuiAddText(g, x, y, hue, text) {
    if (text !== null && typeof text !== 'undefined') text = String(text).toUpperCase();
    g.AddText(x, y + GLOBAL_TEXT_Y_OFFSET, hue, text);
}

function LightBoolFromStatus(scriptName) {
    return GetColorStatus(scriptName) === HUE_TEXT_ACTIVE;
}

function LightButtonGraphic(active) {
    return active ? LIGHT_TOGGLE_ON_GUMP : LIGHT_TOGGLE_OFF_GUMP;
}

function LightButtonHue(active) {
    return active ? LIGHT_TOGGLE_ON_HUE : LIGHT_TOGGLE_OFF_HUE;
}

function LightActiveFillHue(hue) {
    if (hue && hue !== '') return hue;
    return LIGHT_TOGGLE_ACTIVE_FILL_HUE;
}

function LightAddFramedToggleButton(g, id, x, y, active, activeFillHue) {
    // Verde grande quando ON; grigio originale V5 quando OFF.
    var graphic = LightButtonGraphic(active);
    var hue = LightButtonHue(active);
    g.AddButton(id, x, y, graphic, graphic, graphic, hue);
}

function LightTextColor(scriptName) {
    return GetColorStatus(scriptName);
}

function LightAddToggle(g, id, x, y, label, active, tooltip, color) {
    LightAddFramedToggleButton(g, id, x, y + 3, active, LIGHT_TOGGLE_ACTIVE_FILL_HUE);
    g.AddTooltip(tooltip || label || '');
    if (label && label.length > 0) GuiAddText(g, x + 18, y + 2, color || (active ? HUE_TEXT_ACTIVE : HUE_TEXT_DISABLED), label);
}

function LightAddAction(g, id, x, y, label, tooltip, color, textOffset) {
    g.AddButton(id, x, y + 3, 0x4B9, 0x4B9, 0x4B9, '0x03E9');
    g.AddTooltip(tooltip || label || '');
    if (label && label.length > 0) GuiAddText(g, x + (textOffset || 20), y + 2, color || HUE_TEXT_NORMAL, label);
}

function GetLoggedPlayerNameForGui() {
    var name = 'PG';
    try { name = Player.Name(); } catch (e) { name = 'PG'; }
    return name;
}

function AddGuiTitle(g, offsetX, offsetY) {
    GuiAddText(g, offsetX + 10, offsetY + 7, HUE_TITLE_AQUA, 'UODREAMS COMPAGNONE ' + COMPAGNONE_VERSION_LABEL);

    // NOME PG REALE, SENZA CAPS LOCK FORZATO
    g.AddText(offsetX + 10, offsetY + 22 + GLOBAL_TEXT_Y_OFFSET, HUE_PLAYER_ACID, '[' + GetLoggedPlayerNameForGui() + ']');
}

function AddPlayerNameBlock(g, offsetX, offsetY, baseY) {
    // LIGHT 1.0: il nome PG e gia nell'header principale.
}

function AddNavButtons(g, offsetX, offsetY, active) {
    var navY = offsetY + 43;
    LightAddToggle(g, active === 2 ? 1017 : 1015, offsetX + 15,  navY, 'CONFIG', active === 2, active === 2 ? 'Collapse Menu' : 'Config Menu', active === 2 ? HUE_TEXT_ACTIVE : HUE_TEXT_NORMAL);
    LightAddToggle(g, active === 1 ? 1017 : 1016, offsetX + 105, navY, 'CHAMP',  active === 1, active === 1 ? 'Collapse Menu' : 'Champ Selector Menu', active === 1 ? HUE_TEXT_ACTIVE : HUE_TEXT_NORMAL);
    LightAddToggle(g, active === 3 ? 1017 : 1018, offsetX + 185, navY, 'MISC',   active === 3, active === 3 ? 'Collapse Menu' : 'Miscellaneous Menu', active === 3 ? HUE_TEXT_ACTIVE : HUE_TEXT_NORMAL);
    LightAddToggle(g, active === 4 ? 1017 : 1019, offsetX + 260, navY, 'DRESS',  active === 4, active === 4 ? 'Collapse Menu' : 'Dress Menu', active === 4 ? HUE_TEXT_ACTIVE : HUE_TEXT_NORMAL);
}

function AddCheckRow(g, id, xBtn, xText, y, scriptName, label) {
    var active = LightBoolFromStatus(scriptName);
    var textX = xText;
    if (textX - xBtn > 26) textX = xBtn + 26;
    LightAddFramedToggleButton(g, id, xBtn, y + 3, active, LIGHT_TOGGLE_ACTIVE_FILL_HUE);
    g.AddTooltip(label || scriptName || '');
    GuiAddText(g, textX, y + 2, LightTextColor(scriptName), label);
}

function IsResetOrSelectButton(tooltip) {
    if (!tooltip) return false;
    var t = String(tooltip).toLowerCase();
    return t.indexOf('reset') !== -1 ||
           t.indexOf('resett') !== -1 ||
           t.indexOf('selez') !== -1 ||
           t.indexOf('select') !== -1 ||
           t.indexOf('aggiungi') !== -1 ||
           t.indexOf('autoloot') !== -1 ||
           t.indexOf('insur') !== -1;
}

function AddSmallSetButton(g, id, x, y, hue, tooltip) {
    var finalHue = IsResetOrSelectButton(tooltip) ? HUE_BUTTON_PURPLE : (hue || HUE_SMALL_BUTTON);
    g.AddButton(id, x, y, 0x2716, 0x2716, 0x2716, finalHue);
    g.AddTooltip(tooltip || '');
}

function AddBigButton(g, id, x, y, hue, textColor, label, tooltip, textOffset) {
    LightAddAction(g, id, x, y, label, tooltip || label, textColor || HUE_TEXT_NORMAL, textOffset || 20);
}

function AddDressWeaponRow(g, toggleId, setId, xSet, xBtn, xText, y, scriptName, label, hue) {
    AddSmallSetButton(g, setId, xSet, y + 4, hue || '0x03E9', 'Seleziona o resetta ' + label);
    var active = LightBoolFromStatus(scriptName);
    var textX = xText;
    if (textX - xBtn > 26) textX = xBtn + 26;
    LightAddFramedToggleButton(g, toggleId, xBtn, y + 3, active, LIGHT_TOGGLE_ACTIVE_FILL_HUE);
    g.AddTooltip(label || scriptName || '');
    GuiAddText(g, textX, y + 2, LightTextColor(scriptName), label);
}

function AddDressCompactPairRow(g, xLabel, xAxeSet, xAxeBtn, xBsSet, xBsBtn, y, label, axeToggleId, axeSetId, axeScript, bsToggleId, bsSetId, bsScript, hue) {
    var axeActive = axeScript ? LightBoolFromStatus(axeScript) : false;
    var bsActive = bsScript ? LightBoolFromStatus(bsScript) : false;
    var labelColor = (axeActive || bsActive) ? HUE_TEXT_ACTIVE : HUE_TEXT_DISABLED;

    GuiAddText(g, xLabel, y + 2, labelColor, label);

    if (axeSetId && axeScript) {
        AddSmallSetButton(g, axeSetId, xAxeSet, y + 4, hue || '0x03E9', 'Reset/Seleziona AXE ' + label);
    }
    if (axeToggleId && axeScript) {
        LightAddFramedToggleButton(g, axeToggleId, xAxeBtn, y + 3, axeActive, LIGHT_TOGGLE_ACTIVE_FILL_HUE);
        g.AddTooltip('Dress AXE ' + label);
    }

    if (bsSetId && bsScript) {
        AddSmallSetButton(g, bsSetId, xBsSet, y + 4, hue || '0x03E9', 'Reset/Seleziona B.S. ' + label);
    }
    if (bsToggleId && bsScript) {
        LightAddFramedToggleButton(g, bsToggleId, xBsBtn, y + 3, bsActive, LIGHT_TOGGLE_ACTIVE_FILL_HUE);
        g.AddTooltip('Dress B.S. ' + label);
    }
}

