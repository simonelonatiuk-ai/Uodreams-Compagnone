    if (!Orion.BuffExists('Confidence')) {
        Orion.CharPrint(Player.Serial(), 55, 'Confidence...');
        Orion.Cast('Confidence');
        Orion.Wait(200);
        return;
    }

    Orion.CharPrint(Player.Serial(), 25, '*Sti Bbon*');
}

