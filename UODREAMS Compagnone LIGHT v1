function CleanupRuntimeState() {
    var maps = [_eventPrimaryMarked, _eventSecondaryMarked, _eventAggroDone, _eventHighlightDone];

    for (var m = 0; m < maps.length; m++) {
        for (var serial in maps[m]) {
