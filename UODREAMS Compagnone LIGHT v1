function TankerManualeAttack() {
    var honoredTarget = null;
    var activeSerial = '';

    ignoredMobs = ignoredMobs || {};

    while (!Player.Dead()) {
        if (Orion.GetGlobal('StopAllScripts') === 'true') return;

        if (HandleBloodOath()) {
            Orion.Wait(50);
            continue;
        }

        var enemy = GetManualSelectedEnemy();

        // NESSUN TARGET MANUALE SCELTO: NON ATTACCA NESSUNO.
        if (!enemy) {
            activeSerial = '';
            honoredTarget = null;
            Orion.WarMode(false);
            Orion.Wait(150);
            continue;
        }

        var currentSerial = enemy.Serial();

        if (activeSerial !== currentSerial) {
            activeSerial = currentSerial;
            honoredTarget = null;

            Orion.ClearHighlightCharacters(true);
            Orion.ShowStatusbar(currentSerial, 1200, 1200);
            Orion.AddHighlightCharacter(currentSerial, 1283, true);
            Orion.CharPrint(currentSerial, 23, '*TARGET*');
        }

        if (ignoredMobs[currentSerial] || IsIgnoredSummon(enemy)) {
            ignoredMobs[currentSerial] = true;
            Orion.Ignore(currentSerial);
            Orion.SetGlobal('LastEnemySerial', '');
            Orion.RemoveObject('myTarget');
            activeSerial = '';
            honoredTarget = null;
            Orion.WarMode(false);
            Orion.Wait(150);
            continue;
        }

        if (!honoredTarget || honoredTarget.Serial() !== currentSerial) {
            honoredTarget = TryHonorEnemy(enemy) ? enemy : null;
        }

        Orion.WarMode(true);

        while (!Player.Dead() && Orion.ObjectExists(currentSerial)) {
            if (Orion.GetGlobal('StopAllScripts') === 'true') return;

            if (HandleBloodOath()) {
                Orion.Wait(50);
                break;
            }

            // SE CAMBI TARGET CON NextEnemyManual, ESCE SUBITO E PASSA AL NUOVO.
            var selectedSerial = Orion.GetGlobal('LastEnemySerial');

            if (!selectedSerial || selectedSerial === '' || selectedSerial === '0x000') {
                activeSerial = '';
                honoredTarget = null;
                Orion.WarMode(false);
                break;
            }

            if (selectedSerial !== currentSerial) {
                activeSerial = '';
                honoredTarget = null;
                break;
            }

            enemy = Orion.FindObject(currentSerial);

            if (!enemy || !Orion.ObjectExists(currentSerial)) {
                StopManualAttackScripts();
                return;
            }

            if (enemy.Dead && enemy.Dead()) {
                StopManualAttackScripts();
                return;
            }

            if (ignoredMobs[currentSerial] || IsIgnoredSummon(enemy)) {
                ignoredMobs[currentSerial] = true;
                Orion.Ignore(currentSerial);
                Orion.SetGlobal('LastEnemySerial', '');
                Orion.RemoveObject('myTarget');
                activeSerial = '';
                honoredTarget = null;
                Orion.WarMode(false);
                break;
            }

            Orion.WarMode(true);

            if (enemy.Distance() <= 12) {
                Orion.Attack(currentSerial);
            }

            Orion.Wait(100);
        }

        // SE ESCE DAL WHILE PERCHE IL MOB NON ESISTE PIU, STOPPA L'ATTACCO.
        if (currentSerial && !Orion.ObjectExists(currentSerial)) {
            StopManualAttackScripts();
            return;
        }

        Orion.CancelTarget();
        Orion.Wait(100);
    }
}

function GetClosestEnemySolo() {
    Orion.IgnoreReset();
    Orion.Ignore('self');

    var friends = Orion.GetFriendList();
    for (var i = 0; i < friends.length; i++) Orion.Ignore(friends[i]);

    var enemies = Orion.FindTypeEx('any', 'any', 'ground', 'ignoreself|ignorefriends|live|inlos|mobile', 10, 'gray|criminal|red|orange|enemy');
    var filtered = [];

    for (var j = 0; j < enemies.length; j++) {
        var o = enemies[j];
        if (!o) continue;
        if (ignoredMobs[o.Serial()]) continue;

        if (IsIgnoredSummon(o)) {
            Orion.Ignore(o.Serial());
            ignoredMobs[o.Serial()] = true;
            continue;
        }

        filtered.push(o);
    }

    if (!filtered.length) return null;

    filtered.sort(function(a, b) { return a.Distance() - b.Distance(); });
    return filtered[0];
}

