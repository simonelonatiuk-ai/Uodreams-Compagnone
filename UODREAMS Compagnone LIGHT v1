function GetBackpackSerialSimple() {
    var bp = Orion.ObjAtLayer('Backpack');
    if (!bp) return '';
    return String(bp.Serial()).toLowerCase();
}

function ObjIsInBackpack(obj) {
    if (!obj) return false;

    var bpSerial = GetBackpackSerialSimple();
    if (!bpSerial) return false;

    try {
        return String(obj.Container()).toLowerCase() === bpSerial;
    } catch (e) {
        return false;
    }
}

function IsWeaponObjEquipped(obj) {
    if (!obj) return false;

    var serial = String(obj.Serial()).toLowerCase();

    var right = Orion.ObjAtLayer('RightHand');
    var left = Orion.ObjAtLayer('LeftHand');

    if (right && String(right.Serial()).toLowerCase() === serial) return true;
    if (left && String(left.Serial()).toLowerCase() === serial) return true;

    return false;
}

function IsAnyWeaponEquipped() {
    return !!(Orion.ObjAtLayer('RightHand') || Orion.ObjAtLayer('LeftHand'));
}

function IsTalismanObjEquipped(obj) {
    if (!obj) return false;

    var equipped = Orion.ObjAtLayer('Talisman');
    if (!equipped) return false;

    return String(equipped.Serial()).toLowerCase() === String(obj.Serial()).toLowerCase();
}

function ClearDoomEquipState() {
    Orion.WarMode(false);
    Orion.CancelTarget();
    Orion.CancelWaitTarget();

    try {
        Orion.StopWalking();
    } catch (e) {}

    Orion.Wait(80);
}

function EquipDoomWeaponSimple(varName, label) {
    label = label || varName;

    for (var i = 0; i < DOOM_EQUIP_RETRIES; i++) {
        var weapon = Orion.FindObject(varName);

        if (!weapon) {
            Orion.CharPrint(Player.Serial(), 33, '*ARMA NON TROVATA: ' + label + '*');
            Orion.Print(33, 'Doom weapon non trovata: ' + varName);
            return false;
        }

        if (IsWeaponObjEquipped(weapon)) {
            currentWeaponDress = varName;
            Shared.AddVar('active_weapon_script', label);
            return true;
        }

        ClearDoomEquipState();

        // ClassicAssist style:
        // Cast Create Food -> EquipItem
        Orion.Cast('Create Food');
        Orion.Wait(100);

        weapon = Orion.FindObject(varName);

        if (!weapon) {
            Orion.CharPrint(Player.Serial(), 33, '*ARMA PERSA DOPO CREATE FOOD: ' + label + '*');
            return false;
        }

        Orion.CancelTarget();
        Orion.CancelWaitTarget();

        Orion.Equip(weapon.Serial());
        Orion.Wait(DOOM_EQUIP_WAIT);

        weapon = Orion.FindObject(varName);

        if (weapon && IsWeaponObjEquipped(weapon)) {
            currentWeaponDress = varName;
            Shared.AddVar('active_weapon_script', label);
            Orion.CharPrint(Player.Serial(), 65, '*ARMA EQUIPPATA: ' + label + '*');
            return true;
        }

        Orion.CharPrint(Player.Serial(), 33, '*RETRY EQUIP ARMA ' + (i + 1) + '/' + DOOM_EQUIP_RETRIES + ': ' + label + '*');
    }

    Orion.CharPrint(Player.Serial(), 33, '*ERRORE: NON RIESCO A EQUIPPARE ' + label + '*');
    Orion.PlayWav("C:\\Orion Launcher\\OA\\beep.wav");

    return false;
}

function EquipDoomTalismanSimple(varName, label) {
    label = label || varName;

    for (var i = 0; i < DOOM_EQUIP_RETRIES; i++) {
        var talisman = Orion.FindObject(varName);

        if (!talisman) {
            Orion.CharPrint(Player.Serial(), 33, '*TALISMANO NON TROVATO: ' + label + '*');
            Orion.Print(33, 'Doom talisman non trovato: ' + varName);
            return false;
        }

        if (IsTalismanObjEquipped(talisman)) {
            currentTalismanDress = varName;
            Shared.AddVar('active_talisman_script', label);
            return true;
        }

        ClearDoomEquipState();

        talisman = Orion.FindObject(varName);

        if (!talisman) {
            Orion.CharPrint(Player.Serial(), 33, '*TALISMANO PERSO: ' + label + '*');
            return false;
        }

        Orion.Equip(talisman.Serial());
        Orion.Wait(DOOM_EQUIP_WAIT);

        talisman = Orion.FindObject(varName);

        if (talisman && IsTalismanObjEquipped(talisman)) {
