    if (checked) { g.AddText(sx, rowY, hasMount ? 53 : 0, hasMount ? 'X' : '0'); }
    g.AddButton(3003, sx + 20, rowY - 2, GetCheckboxStatus('autoMount'), GetCheckboxStatus('autoMount'), GetCheckboxStatus('autoMount'), '');
    g.AddTooltip('Toggle Auto Mount pet');
    g.Update();
}

