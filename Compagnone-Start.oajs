function GUIMisc(){
    var g = BeginTab(3);
    var offsetX = LAYOUT.offsetX;
    var offsetY = LAYOUT.offsetY;
    var prompt = 150;
    DrawFrame(g, 16);
    DrawNav(g, 'misc');

    g.AddText(offsetX + 166, offsetY + 120, 53, '*UTILITIES*');

    // AddTo Autoloot & Insure
    g.AddButton(5031, offsetX + 240, offsetY + prompt + 28, '0x2716', '0x2716', '0x2716', '85');
    g.AddTooltip('Seleziona un oggetto da insurare');
    g.AddText(offsetX + 260, offsetY + prompt + 25, 65, 'ADD to Insure list');
    g.AddText(offsetX + 60, offsetY + prompt + 5, GetColorStatus('SuperInsura'), 'Auto Insura Arte e Skull');
    g.AddButton(3001, offsetX + 25, offsetY + prompt, GetCheckboxStatus("SuperInsura"), GetCheckboxStatus("SuperInsura"), GetCheckboxStatus("SuperInsura"), '');
    g.AddButton(5032, offsetX + 240, offsetY + prompt + 8, '0x2716', '0x2716', '0x2716', '95');
    g.AddTooltip('Seleziona un oggetto da autolootare');
    g.AddText(offsetX + 260, offsetY + prompt + 5, 65, 'ADD to Autoloot');

    prompt += 30;
    g.AddText(offsetX + 60, offsetY + prompt + 5, GetColorStatus('Durability_Watcher'), 'Check Durability');
    g.AddButton(3002, offsetX + 25, offsetY + prompt, GetCheckboxStatus("Durability_Watcher"), GetCheckboxStatus("Durability_Watcher"), GetCheckboxStatus("Durability_Watcher"), '');

g.AddButton(3062, offsetX + 240, offsetY + prompt + 24, '0x2716', '0x2716', '0x2716', '31');
g.AddTooltip('Honora te stesso');
g.AddText(offsetX + 260, offsetY + prompt + 21, 65, 'Honorati scemo');
    


// ===== FAMA KARMA / HIDE CORPSE =====
// Blocco destro più compatto e leggermente più alto

var rbBaseY = offsetY + prompt + 45;
var rbStep  = 24;

// X blocco destro
var rbXReset  = offsetX + 240;   // pallino selezione/reset
var rbXRecall = offsetX + 258;   // recall/dress, più vicino al primo
var rbXText   = offsetX + 285;   // testo

// FAMA / KARMA
g.AddButton(5113, rbXReset, rbBaseY + 3, '0x2716', '0x2716', '0x2716', '2770');
g.AddTooltip('Mostra Fama e Karma');

g.AddText(rbXText - 30, rbBaseY - 1, 22, '$$$ : FamaKarma');

// HIDE CORPSE
var hcY    = rbBaseY + rbStep;
var hcBtnX = rbXRecall - 30;

g.AddButton(5110, hcBtnX, hcY + 2,
    GetCheckboxStatus("hideCorpse"),
    GetCheckboxStatus("hideCorpse"),
    GetCheckboxStatus("hideCorpse"),
    ''
);
g.AddTooltip('Toggle Hide Corpse');

// ⬅️ testo avvicinato alla checkbox
g.AddText(rbXText - 20, hcY + 6, GetColorStatus('hideCorpse'), 'Hide Corpses');

// CLICCA TUTTO (sotto Nascondi Corpi)
var ctY    = hcY + rbStep;        // subito sotto Hide Corpse
var ctBtnX = hcBtnX;              // stessa X della checkbox sopra

g.AddButton(5111, ctBtnX, ctY + 2,
    GetCheckboxStatus("ClickEverythingAround1Tile"),
    GetCheckboxStatus("ClickEverythingAround1Tile"),
    GetCheckboxStatus("ClickEverythingAround1Tile"),
    ''
);
g.AddTooltip('Toggle Clicca Tutto');

// testo allineato e spacing identico
g.AddText(rbXText - 20, ctY + 6, GetColorStatus('ClickEverythingAround1Tile'), 'Clikk tutt');

// AUTO HIDE (sotto CLICCA TUTTO)
var ahY    = ctY + rbStep;   // una riga sotto
var ahBtnX = hcBtnX;         // stessa colonna checkbox

g.AddButton(5112, ahBtnX, ahY + 2,
    GetCheckboxStatus("AutoHide"),
    GetCheckboxStatus("AutoHide"),
    GetCheckboxStatus("AutoHide"),
    ''
);
g.AddTooltip('Toggle Auto Hide');

g.AddText(rbXText - 20, ahY + 6, GetColorStatus('AutoHide'), 'Auto Hide');

// AUTO VAMPIRIC (sotto AUTO HIDE)
var avY    = ahY + rbStep;   // una riga sotto
var avBtnX = hcBtnX;         // stessa colonna checkbox

g.AddButton(4321, avBtnX, avY + 2,
    GetCheckboxStatus("AutoVampiricEmbrace"),
    GetCheckboxStatus("AutoVampiricEmbrace"),
    GetCheckboxStatus("AutoVampiricEmbrace"),
    ''
);
g.AddTooltip('Toggle Auto Vampiric Embrace');

g.AddText(rbXText - 20, avY + 6, GetColorStatus('AutoVampiricEmbrace'), 'Auto Vampiric');

// RECALL CASA
var rcasaY = avY + rbStep + 5;
g.AddText(hcBtnX, rcasaY + 6, 65, 'Recall Casa');
g.AddButton(5105, offsetX + 340, rcasaY + 8, '0x04B9', '0x04BA', '0x04B9', '');
g.AddTooltip('Esegui Recall Casa');

// RECALL LUNA BANK
var rlbankY = rcasaY + rbStep;
g.AddText(hcBtnX, rlbankY + 6, 65, 'Recall Luna Bank');
g.AddButton(5107, offsetX + 340, rlbankY + 8, '0x04B9', '0x04BA', '0x04B9', '');
g.AddTooltip('Esegui Recall Luna Bank');

    prompt += 30;
    g.AddText(offsetX + 60, offsetY + prompt + 5, GetColorStatus('AutoLogoutOnDeath'), 'Auto Logout on death');
    g.AddButton(3005, offsetX + 25, offsetY + prompt, GetCheckboxStatus("AutoLogoutOnDeath"), GetCheckboxStatus("AutoLogoutOnDeath"), GetCheckboxStatus("AutoLogoutOnDeath"), '');

    prompt += 30;
    g.AddText(offsetX + 60, offsetY + prompt + 5, GetColorStatus('GoldRunnerChase95'), 'Gold Diggers');
    g.AddButton(3006, offsetX + 25, offsetY + prompt, GetCheckboxStatus("GoldRunnerChase95"), GetCheckboxStatus("GoldRunnerChase95"), GetCheckboxStatus("GoldRunnerChase95"), '');
    prompt += 30;
    g.AddText(offsetX + 60, offsetY + prompt + 5, GetColorStatus('SbloccaSeFermo'), 'SBORRAMI');
    g.AddButton(3007, offsetX + 25, offsetY + prompt, GetCheckboxStatus("SbloccaSeFermo"), GetCheckboxStatus("SbloccaSeFermo"), GetCheckboxStatus("SbloccaSeFermo"), '');

    prompt += 30;
    g.AddText(offsetX + 60, offsetY + prompt + 5, GetColorStatus('doomBoneCutter'), 'BoneCutter DOOM');
    g.AddButton(3008, offsetX + 25, offsetY + prompt, GetCheckboxStatus("doomBoneCutter"), GetCheckboxStatus("doomBoneCutter"), GetCheckboxStatus("doomBoneCutter"), '');

    prompt += 30;
    g.AddText(offsetX + 60, offsetY + prompt + 5, GetColorStatus('Nipo'), 'Sabbia Niporailem');
    g.AddButton(3009, offsetX + 25, offsetY + prompt, GetCheckboxStatus("Nipo"), GetCheckboxStatus("Nipo"), GetCheckboxStatus("Nipo"), '');

    prompt += 30;
    g.AddText(offsetX + 60, offsetY + prompt + 5, GetColorStatus('AggroMobs'), 'Auto Aggro Mobs');
    g.AddButton(3015, offsetX + 25, offsetY + prompt, GetCheckboxStatus("AggroMobs"), GetCheckboxStatus("AggroMobs"), GetCheckboxStatus("AggroMobs"), '');

    prompt += 30;
    g.AddText(offsetX + 60, offsetY + prompt + 5, GetColorStatus('AutoHonorMob'), 'Auto Honor Enemy');
    g.AddButton(3016, offsetX + 25, offsetY + prompt, GetCheckboxStatus("AutoHonorMob"), GetCheckboxStatus("AutoHonorMob"), GetCheckboxStatus("AutoHonorMob"), '');

    prompt += 30;
    g.AddText(offsetX + 60, offsetY + prompt + 5, GetColorStatus('CercaOggettoTerra'), 'Cerca Oggetto a Terra');
    g.AddButton(3017, offsetX + 25, offsetY + prompt, GetCheckboxStatus("CercaOggettoTerra"), GetCheckboxStatus("CercaOggettoTerra"), GetCheckboxStatus("CercaOggettoTerra"), '');
    g.AddButton(1023, offsetX + 205, offsetY + prompt+8, '0x2716', '0x2716', '0x2716', '15');
    g.AddTooltip('Aggiungi ITEM alla lista');
    
    prompt += 30;
g.AddText(offsetX + 60, offsetY + prompt + 5, GetColorStatus('AutoDoomGauntlet'), 'DOOM');
g.AddButton(4018, offsetX + 25, offsetY + prompt, GetCheckboxStatus("AutoDoomGauntlet"), GetCheckboxStatus("AutoDoomGauntlet"), GetCheckboxStatus("AutoDoomGauntlet"), '');

// AGGIUNTA: Frecce R1-R6 accanto al tasto DOOM
    for (var i = 1; i <= 6; i++) {
        var xArrow = offsetX + 80 + (i * 20); // Posizionamento orizzontale dinamico
        // Crea la freccetta (0x04B9)
        g.AddButton(4018 + i, xArrow, offsetY + prompt + 25, '0x04B9', '0x04BA', '0x04B9', '');
        // Aggiunge l'etichetta R1, R2... sopra la freccia
        g.AddText(xArrow + 0, offsetY + prompt +5, '0x0481', 'R' + i);
    }
    
    prompt += 50;
    g.AddLine(offsetX + 60, offsetY + prompt + 1, offsetX + 320, offsetY + prompt + 1, 'white', 2);

    prompt += 15;
    g.AddText(offsetX + 60, offsetY + prompt + 5, GetColorStatus('SpegniTutto'), "STOPPA TUTTO");
    g.AddButton(2010, offsetX + 25, offsetY + prompt, GetCheckboxStatus("SpegniTutto"), GetCheckboxStatus("SpegniTutto"), GetCheckboxStatus("SpegniTutto"), '');

    g.Update();
}

