function GeneralHighlight() {
    Orion.Print("Avvio monitor per Generali");

    var targetRoles = ['the general']; //aggiungere nome npc da segnalare

    while (!Player.Dead()) {
        var found = Orion.FindTypeEx(
            '0x0190|0x0191',
            '-1',
            'ground',
            'live|mobile|ignorefriends|ignoreself|inlos',
            18,
            'gray|red|orange|criminal|enemy'
        );

        for (var i = 0; i < found.length; i++) {
            var mob = found[i];
            if (!mob || !mob.Serial()) continue;
            var propsRaw = Orion.GetProperties(mob.Serial());
            if (!propsRaw || typeof propsRaw !== "string") continue;

            var propsLower = propsRaw.replace(/[\n\r]/g, ' ').toLowerCase();

            for (var r = 0; r < targetRoles.length; r++) {
                var role = targetRoles[r];
                if (propsLower.indexOf(role) !== -1) {
                    Orion.AddHighlightCharacter(mob.Serial(), 0x0480, true); //mettere colore che si vuole per highlight
                    Orion.CharPrint(mob.Serial(), 65, "*GENERALE*");
                    break;
                }
            }
        }

        Orion.Wait(500);
    }
}

function SOLOGENERAL() {
    Orion.SetGlobal('StopAllScripts', 'false');

    StartGeneralProfile();
    if (!Orion.ScriptRunning('GeneralHighlight')) {
        Orion.Exec('GeneralHighlight');
    }
    KillGenerali();
}

function StartGeneralProfile() {
    if (!Orion.ScriptRunning('CheckAndDispelRevenant')) Orion.Exec('CheckAndDispelRevenant');
    if (!Orion.ScriptRunning('AutoBushidoAbilities')) Orion.Exec('AutoBushidoAbilities');
    if (!Orion.ScriptRunning('autoMount')) Orion.Exec('autoMount');
    if (!Orion.ScriptRunning('Durability_Watcher')) Orion.Exec('Durability_Watcher');
    if (!Orion.ScriptRunning('SuperInsura')) Orion.Exec('SuperInsura');
    if (!Orion.ScriptRunning('AutoConsecrate')) Orion.Exec('AutoConsecrate');
    if (!Orion.ScriptRunning('AutoDivine')) Orion.Exec('AutoDivine');
    if (!Orion.ScriptRunning('AutoLogoutOnDeath')) Orion.Exec('AutoLogoutOnDeath');
    if (!Orion.ScriptRunning('UseSpecialAbilities')) Orion.Exec('UseSpecialAbilities');
}

function FindGenerali() {
    var found = Orion.FindTypeEx(
        '0x0190|0x0191',
        '-1',
        'ground',
        'live|mobile|ignorefriends|ignoreself|inlos',
        18,
        'gray|red|orange|criminal|enemy'
    );

    var results = [];

    for (var i = 0; i < found.length; i++) {
        var mob = found[i];

        if (!mob || !mob.Serial()) {
            continue;
        }

        if (typeof ignoredMobs !== 'undefined' && ignoredMobs[mob.Serial()]) {
            continue;
        }

        if (typeof isIgnoredSummon === "function" && isIgnoredSummon(mob)) {
            continue;
        }

        var props = Orion.GetProperties(mob.Serial());

        if (!props || typeof props !== "string") {
            continue;
        }

        var normalized = props.replace(/[\n\r]/g, ' ').toLowerCase();

        if (normalized.indexOf('the general') !== -1) {
            results.push(mob);
        }
    }

    return results;
}

function KillGenerali() {
    Orion.Print("Ricerca e attacco dei GENERALI...");

    while (!Player.Dead()) {
        if (Orion.GetGlobal('StopAllScripts') === 'true') {
            return;
        }

        if (HandleBloodOath()) {
            continue;
        }

        var generali = FindGenerali();

        if (!generali || generali.length === 0) {
            Orion.Wait(500);
            continue;
        }

        for (var i = 0; i < generali.length; i++) {
            if (Orion.GetGlobal('StopAllScripts') === 'true') {
                return;
            }

            if (HandleBloodOath()) {
                break;
            }

            var mob = generali[i];

            if (!mob || !Orion.ObjectExists(mob.Serial())) {
                continue;
            }

            var currentSerial = mob.Serial();

            if (ignoredMobs[currentSerial] || isIgnoredSummon(mob)) {
                ignoredMobs[currentSerial] = true;
                Orion.Ignore(currentSerial);
                continue;
            }

            Orion.AddHighlightCharacter(currentSerial, 0x0480, true);

            TryHonorEnemy(mob);

            while (!Player.Dead() && Orion.ObjectExists(currentSerial)) {
                if (Orion.GetGlobal('StopAllScripts') === 'true') {
                    return;
                }

                if (HandleBloodOath()) {
                    break;
                }

                var refreshed = Orion.FindObject(currentSerial);

                if (!refreshed || refreshed.Dead()) {
                    break;
                }

                if (ignoredMobs[currentSerial] || isIgnoredSummon(refreshed)) {
                    ignoredMobs[currentSerial] = true;
                    Orion.Ignore(currentSerial);
                    break;
                }

                if (refreshed.Distance() > 1) {
                    Orion.WalkTo(refreshed.X(), refreshed.Y(), refreshed.Z(), 1, 255, 1, 2, 5000);
                    Orion.Wait(100);
                }

                if (refreshed.Distance() <= 12) {
                    Orion.Attack(currentSerial);
                }

                Orion.Wait(100);
            }

            Orion.CancelTarget();
        }

        Orion.Wait(300);
    }
}

function AutoReEquip() {
    Orion.Print("▶️ Monitor Disarm attivo...");

    while (!Player.Dead()) {
        // Se disarmato
        if (Orion.BuffExists('Disarm')) {
            while (Orion.BuffExists('Disarm')) {
                Orion.Wait(300);
            }

            // Trova l'arma salvata "kaldun"
            var arma = Orion.FindObject('kaldun');

            if (arma) {
                Orion.Equip(arma.Serial());
                Orion.CharPrint(Player.Serial(), 65, "Equipaggiata arma: " + arma.Name());
            } else {
                Orion.CharPrint(Player.Serial(), 33, "Nessuna arma salvata (kaldun)");
            }
        }

        // 🔹 Nuovo controllo: se forza > 125 e oggetto 0x404A4CAC è nel backpack
        if (Player.Str() > 125) {
            var oggetto = Orion.FindObject('0x404A4CAC');
            if (oggetto && oggetto.Container() == Orion.ObjAtLayer('Backpack').Serial()) {
                Orion.Equip(oggetto.Serial());
                Orion.CharPrint(Player.Serial(), 65, "Equipaggiato oggetto per forza > 125");
            }
        }

        Orion.Wait(300);
    }
}


function BoneScavengerSimple() {
    var ignoraSerial = parseInt('0x4053424E');
    var piccozzaID = '0x0E86';
    var boneGraphics = ['0xAF1E', '0xA331', '0xABCE', '0xABCF', '0xABD0'];

    var picca = Orion.FindType(piccozzaID, '-1', 'backpack');
    if (!picca.length) {
        Orion.CharPrint(Player.Serial(), 33, '⚠️ Piccozza non trovata nello zaino!');
        return;
    }
    Orion.Equip(picca[0]);
    Orion.CharPrint(Player.Serial(), 65, '🪓 Piccozza equipaggiata');

    while (!Player.Dead()) {
        var bones = Orion.FindTypeEx(boneGraphics.join('|'), '-1', 'ground', 'item', 14);

        for (var i = 0; i < bones.length; i++) {
            var bone = bones[i];
            if (!bone || bone.Serial() === ignoraSerial) continue;

            Orion.CharPrint(bone.Serial(), 65, '*TROVATO*');
            Orion.Wait(200);

            Orion.UseObject(bone.Serial());
            Orion.Wait(300);

            Orion.UseObject(picca[0]);
            if (Orion.WaitForTarget(1000)) {
                Orion.TargetObject(bone.Serial());
                Orion.Wait(300);
            }
        }

        Orion.Wait(500);
    }
}


function hideCorpse() {
    while (!Player.Dead()) {

        var corpi = Orion.FindType('0x2006', '0xFFFF', 'ground');

        for (var i = 0; i < corpi.length; i++) {
            var corpo = Orion.FindObject(corpi[i]);
            if (corpo && corpo.Distance() <= 18) { // Controlla che sia valido e entro 16 tile
                Orion.Hide(corpo.Serial()); // Nascondi l'oggetto
            }
        }
        Orion.Wait(100);
    }
}

function NextEnemyArcher() {
    var enemies = Orion.FindTypeEx(
        'any', 'any', 'ground',
        'ignoreself|ignorefriends|live|inlos|mobile',
        12,
        'gray|criminal|red|enemy|orange'
    );

    var validEnemies = enemies.filter(function (mob) {
        return Orion.ObjectExists(mob.Serial());
    });

    if (validEnemies.length === 0) {
        Orion.CharPrint(Player.Serial(), 33, "Nessun nemico trovato");
        Orion.ClearHighlightCharacters(true);
        Orion.SetGlobal('LastEnemySerial', '');
        return;
    }

    validEnemies.sort(function (a, b) {
        return a.Distance() - b.Distance();
    });

    var lastSerial = Orion.GetGlobal('LastEnemySerial');
    var idx = -1;
    if (lastSerial) {
        for (var i = 0; i < validEnemies.length; i++) {
            if (validEnemies[i].Serial() == lastSerial) {
                idx = i;
                break;
            }
        }
    }

    var nextIndex = (idx === -1) ? 0 : (idx + 1) % validEnemies.length;
    var target = validEnemies[nextIndex];

    Orion.ClearHighlightCharacters(true);
    Orion.AddObject('myTarget', target.Serial());
    Orion.ShowStatusbar(target.Serial(), 1200, 1200);
    Orion.AddHighlightCharacter(target.Serial(), 0x0480, true);

    if (lastSerial && Orion.ObjectExists(lastSerial)) {
        Orion.CharPrint(lastSerial, 0, " ");
    }

    Orion.CharPrint(target.Serial(), 35, '*NEMICO*: ' + target.Name());
    Orion.SetGlobal('LastEnemySerial', target.Serial());
}


function NextFriendTarget() {
    var friends = Orion.FindTypeEx(
        'any', 'any', 'ground',
        'ignoreself|ignoreenemies|live|inlos|mobile',
        12,
        'friend|green|blue'
    );

    var validFriends = friends.filter(function (mob) {
        return Orion.ObjectExists(mob.Serial());
    });

    if (validFriends.length === 0) {
        Orion.CharPrint(Player.Serial(), 65, "Nessun amico trovato!");
        Orion.ClearHighlightCharacters(true);
        Orion.SetGlobal('LastFriendSerial', '');
        Orion.SetGlobal('FriendIndex', -1);
        return;
    }

    var friendIndex = parseInt(Orion.GetGlobal('FriendIndex'), 10);
    if (isNaN(friendIndex) || friendIndex >= validFriends.length - 1) {
        friendIndex = 0;
    } else {
        friendIndex += 1;
    }

    var target = validFriends[friendIndex];

    Orion.ClearHighlightCharacters(true);
    Orion.AddObject('myFriend', target.Serial());
    Orion.ShowStatusbar(target.Serial(), 1000, 200);
    Orion.AddHighlightCharacter(target.Serial(), 0x0044, true);

    var lastSerial = Orion.GetGlobal('LastFriendSerial');
    if (lastSerial && Orion.ObjectExists(lastSerial)) {
        Orion.CharPrint(lastSerial, 0, " ");
    }

    Orion.CharPrint(target.Serial(), 70, '*AMICO*: ' + target.Name());
    Orion.SetGlobal('LastFriendSerial', target.Serial());
    Orion.SetGlobal('FriendIndex', friendIndex);
}

function HealSelectedFriendChivalry() {
    var friendSerial = Orion.GetGlobal('LastFriendSerial');

    if (!friendSerial || !Orion.ObjectExists(friendSerial)) {
        Orion.CharPrint(Player.Serial(), 65, "Seleziona prima un amico!");
        return;
    }

    var friend = Orion.FindObject(friendSerial);

    if (!friend || friend.Hits() === friend.MaxHits()) {
        Orion.CharPrint(friendSerial, 65, friend.Name() + " è già full vita!");
        return;
    }

    if (Orion.ObjectExists(friendSerial)) {
        Orion.CharPrint(friendSerial, 55, "Curando: " + friend.Name());
        Orion.Cast('Close Wounds', friendSerial);
        Orion.Wait(600);
    }
}

function EnsureCurseWeaponActive(enemyObj) {
    var CURSE_HP_THRESHOLD = 35; // % vita sotto la quale attivare CW
    var MIN_MANA_FOR_CURSE = 5;  // mana minimo di sicurezza
    var MAX_CURSE_SPAM_MS  = 2500; // anticiclo infinito: insisti max 2.5s

    var hpPercent = (Player.Hits() / Player.MaxHits()) * 100;
    if (hpPercent > CURSE_HP_THRESHOLD) return;
    if (Orion.BuffExists('Curse Weapon')) return;
    if (Player.Mana() < MIN_MANA_FOR_CURSE) return;

    var enemy = enemyObj;
    if (!enemy || typeof enemy.Serial !== 'function') {
        enemy = Orion.FindObject(enemyObj);
    }
    if (!enemy || enemy.Hits() <= 0) return;
    if (enemy.Distance() > 12) return;

    var start = Orion.Now();
    while (!Player.Dead()) {

        hpPercent = (Player.Hits() / Player.MaxHits()) * 100;
        if (hpPercent > CURSE_HP_THRESHOLD) break;
        if (Orion.BuffExists('Curse Weapon')) break;
        if (Player.Mana() < MIN_MANA_FOR_CURSE) break;
        if (Orion.Now() - start > MAX_CURSE_SPAM_MS) break;

        Orion.Cast('Curse Weapon');
        Orion.Wait(220);
    }
}

function AutoCurseWeapon() {
    var THRESHOLD = 65;

    while (!Player.Dead()) {

        if (Player.Hits() < THRESHOLD) {

            if (!Orion.BuffExists('Curse Weapon')) {

                if (Player.Mana() >= 5) {
                    Orion.Cast('Curse Weapon');
                    Orion.Wait(600);
                }

            }

        }

        Orion.Wait(100);
    }
}


function AutoVampiricEmbrace() {
    Orion.Print("AutoVampiricEmbrace avviato");

    // === REAGENTI (UODREAMS) ===
    var REAG_NOX_CRYSTAL = '0x0F8E'; // Nox Crystal
    var REAG_PIG_IRON   = '0x0F8A'; // Pig Iron
    var REAG_BAT_WING   = '0x0F78'; // Bat Wing

    // === COMBAT CHECK ===
    var COMBAT_GRACE_MS = 8000;
    var lastCombatTs = 0;

    function hasAllReagents() {
        return (
            Orion.Count(REAG_NOX_CRYSTAL, -1, 'backpack') > 0 &&
            Orion.Count(REAG_PIG_IRON,   -1, 'backpack') > 0 &&
            Orion.Count(REAG_BAT_WING,   -1, 'backpack') > 0
        );
    }

    function inCombatNow() {
        var atkSerial = Orion.ClientLastAttack();
        var atk = atkSerial ? Orion.FindObject(atkSerial) : null;

        // nemico valido vicino → combat
        if (atk && atk.Hits() > 0 && atk.Distance() <= 12) {
            lastCombatTs = Orion.Now();
            return true;
        }

        // finestra di sicurezza post-combat
        return (Orion.Now() - lastCombatTs) < COMBAT_GRACE_MS;
    }

    while (true) {
        Orion.Wait(500);

        if (Player.Dead() || Player.Hidden()) continue;

        // Vampiric già attivo
        if (Orion.BuffExists('0x75C4')) continue;

        // reagenti completi
        if (!hasAllReagents()) continue;

        // solo full HP
        if (Player.Hits() !== Player.MaxHits()) continue;

        // solo fuori combat
        if (inCombatNow()) continue;

        // cast
        Orion.CancelTarget();
        Orion.Cast('113'); // Vampiric Embrace
        Orion.Wait(2000);
    }
}


// === ENEMY SELECT (premi tasto per scorrere) ===
function SelectEnemy() {
    Orion.ClearJournal();
    var enemySerial = FindNearestEnemy_PvP();
    if (!enemySerial) {
        Orion.Print('65', '❌ Nessun nemico visibile');
        return;
    }

    var enemy = Orion.FindObject(enemySerial);
    if (!enemy) return;

    // Colore notoriety per messaggio
    var noto = enemy.Notoriety();
    var color = 906; // default orange
    if (noto == 1) color = 2119; // gray
    else if (noto == 3) color = 906; // orange
    else if (noto == 6) color = 33; // red

    Orion.ClearHighlightCharacters();
    Orion.AddHighlightCharacter(enemySerial, 50);
    Orion.CharPrint(enemySerial, color, "★ " + enemy.Name().toUpperCase() + " (" + enemy.Hits('%') + "% HP)");

    // salva il target globale
    Orion.SetGlobal('global_enemy', enemySerial);
    Orion.ClientLastTarget(enemySerial);
    Orion.TargetSystemSerial(enemySerial);

    Orion.Print(color, "🎯 Target: " + enemy.Name());
}

// === ATTACK ENEMY (premi tasto per attaccare il target selezionato) ===
function AttackEnemy() {
    var serial = Orion.GetGlobal('global_enemy');
    if (!serial || serial === '0x000' || !Orion.FindObject(serial)) {
        Orion.Print('35', '⚠️ Nessun target selezionato');
        return;
    }
    Orion.Attack(serial);
    Orion.CharPrint(serial, '33', '⚔️ ATTACCO!');
}

// === TROVA NEMICO PIÙ VICINO ===
function FindNearestEnemy_PvP() {
    // reset ignore ogni 1s per scorrere
    var resetTime = 800;
    var now = Orion.Now();
    var last = Orion.GetGlobal("FindNearestEnemy_PvP_LastTime");
    if (now - last > resetTime) Orion.IgnoreReset();

    Orion.Ignore('self');

    // ricerca dei modelli umani (UO standard)
    var types = "0x0190|0x0191|0x025D|0x025E|0x029A|0x029B|0x02EC|0x0317|0x031F";
    var enemies = Orion.FindType(types, "-1", "ground", "near|mobile|live|ignorefriends", 18, "enemy|criminal|gray|orange|red");

    if (!enemies.length) {
        Orion.IgnoreReset();
        Orion.SetGlobal('global_enemy', '0x000');
        return '';
    }

    Orion.SetGlobal("FindNearestEnemy_PvP_LastTime", Orion.Now());
    // ignora quello selezionato per poter ciclare al prossimo
    Orion.Ignore(enemies[0]);
    return enemies[0];
}

function FindNearestEnemy_OAKS() {

    Orion.Ignore('self');

    var friends = Orion.GetFriendList();
    for (var i = 0; i < friends.length; i++) {
        Orion.Ignore(friends[i]);
    }

    var enemies = Orion.FindTypeEx(
        'any',
        'any',
        'ground',
        'ignoreself|ignorefriends|live|inlos|near',
        4, // 🔥 RAGGIO STRETTO
        'gray|criminal|red|enemy|orange|blue'
    );

    if (!enemies.length) return null;

    enemies.sort(function (a, b) {
        return a.Distance() - b.Distance();
    });

    return enemies[0];
}


function AttackNearestEnemy_OAKS() {

    var target = FindNearestEnemy_OAKS();
    if (!target) return false;

    Orion.ShowStatusbar(target.Serial(), 1150, 1200);

    while (!Player.Dead() && Orion.ObjectExists(target.Serial())) {

        var dist = target.Distance();

        // 🔴 se esce dal range → basta
        if (dist > 4) {
            Orion.CloseStatusbar(target.Serial());
            return false;
        }

        // attacco statico
        Orion.Attack(target.Serial());
        Orion.Wait(120);
    }

    Orion.CloseStatusbar(target.Serial());
    return true;
}


function Oaks() {

 var railCoordinates = [
[5554, 3757], [5545, 3754], [5535, 3751], [5525, 3751], [5517, 3764], [5519, 3772], [5517, 3783], [5526, 3786], [5530, 3780], [5536, 3780], [5544, 3783], [5554, 3791], [5562, 3800], [5568, 3804],
[5547, 3775], [5546, 3774], [5556, 3784], [5566, 3787], [5573, 3792], [5575, 3798], [5580, 3788],[5592, 3783], [5598, 3779], [5617, 3778], [5605, 3742], [5597, 3740], [5589, 3733], [5585, 3727],
[5589, 3718], [5580, 3707], [5565, 3707], [5553, 3714], [5548, 3722], [5554, 3727], [5565, 3728], [5545, 3731], [5536, 3730], [5526, 3738], [5525, 3748], [5535, 3751], [5546, 3754], [5559, 3757]
    ];

    var currentIndex = 0;

    while (!Player.Dead()) {

        if (Orion.GetGlobal('StopAllScripts') === 'true') return;

        if (currentIndex >= railCoordinates.length) {
            currentIndex = 0;
        }

        var coord = railCoordinates[currentIndex];

        Orion.WalkTo(
            coord[0],
            coord[1],
            Player.Z(),
            1,
            255,
            1,
            10,
            10000
        );

        // ⏱ micro-check area (come Marble)
        var checkDuration = 100;
        var startTime = Orion.Now();

        while (Orion.Now() - startTime < checkDuration) {

            if (AttackNearestEnemy_OAKS()) {
                // resetta solo se combatte davvero
                startTime = Orion.Now();
            } else {
                Orion.Wait(50);
            }
        }

        currentIndex++;
        Orion.Wait(10);
    }
}


function BoneScavengerEquipped() {
    var itemColor = '0x05DD'; // Colore degli oggetti a terra
    var ignoraSerial = '0x4053424E';

    Orion.Print('0x60', '▶ Script AVVIATO (Controllo mani...)');

    while (!Player.Dead()) {
        // 1. Identifica la piccozza nelle mani
        // Slot 1 = Mano Destra, Slot 2 = Mano Sinistra
        var picca = Orion.ObjAtLayer(1); // Prova la mano destra
        if (!picca || picca.Graphic() !== '0x0E86') {
            picca = Orion.ObjAtLayer(2); // Prova la mano sinistra
        }

        // Se non è in mano, la cerchiamo un'ultima volta nello zaino
        if (!picca || picca.Graphic() !== '0x0E86') {
            var findInPack = Orion.FindType('0x0E86', '-1', 'backpack', 'item|recurse');
            if (findInPack.length > 0) {
                picca = Orion.FindObject(findInPack[0]);
            }
        }

        if (!picca) {
            Orion.Print(33, '⚠️ Piccozza non trovata! Equipaggiala o mettila nello zaino.');
            Orion.Wait(2000);
            continue;
        }

        // 2. Cerca oggetti del colore specifico
        var objects = Orion.FindTypeEx('any', itemColor, 'ground', 'item', 33);

        for (var i = 0; i < objects.length; i++) {
            var obj = objects[i];
            
            if (!obj || obj.Serial() === ignoraSerial) continue;

            Orion.CharPrint(obj.Serial(), 65, '*OGGETTO RILEVATO*');
            
            // Azione
            Orion.CancelTarget();
            Orion.UseObject(picca.Serial());
            
            if (Orion.WaitForTarget(1500)) {
                Orion.TargetObject(obj.Serial());
                Orion.Wait(100);
                
                // Ignora per evitare loop sullo stesso oggetto
                Orion.Ignore(obj.Serial());
            }
        }

        Orion.Wait(200);
    }
}

function ToggleDoomGauntlet() {
    // Se lo script è già in esecuzione, lo spegne
    if (Orion.ScriptRunning('AutoDoomGauntlet')) {
        Orion.Terminate('AutoDoomGauntlet');
        Orion.CharPrint(Player.Serial(), 33, "DOOM Gauntlet Disattivato");
    } 
    // Altrimenti attiva tutti gli script richiesti
    else {
        Orion.SetGlobal('StopAllScripts', 'false');
        
        if (!Orion.ScriptRunning('AutoVampiricEmbrace')) {
            Orion.Exec('AutoVampiricEmbrace', 'true');
        }
        if (!Orion.ScriptRunning('doomBoneCutter')) {
            Orion.Exec('doomBoneCutter', 'true');
        }
        if (!Orion.ScriptRunning('AutoLogoutOnDeath')) {
            Orion.Exec('AutoLogoutOnDeath', 'true');
        }
        
        Orion.Exec('AutoDoomGauntlet', 'true');
        Orion.CharPrint(Player.Serial(), 65, "DOOM Gauntlet ATTIVATO!");
    }
    
    // Aggiorna la grafica della GUI
    GUI();
}

// ============================================================================
// DOOM GAUNTLET MODULE - COMPAGNONE COMPATIBLE
// ============================================================================

// --- VARIABILI GLOBALI SPECIFICHE PER DOOM ---
var currentDressList = "";

// --- COORDINATE PERCORSI (RAILS) ---
var rails = {
    r1:  [[439, 432], [450, 432], [464, 432], [469, 428], [470, 428], [473, 428]],
    r1m: [[485, 455]],
    r2:  [[486, 450], [486, 439], [482, 432], [472, 432], [470, 432], [462, 492], [462, 493], [462, 496]],
    r2m: [[484, 517]],
    r3:  [[479, 507], [468, 502], [468, 493], [453, 468], [403, 500], [403, 501], [403, 504]],
    r3m: [[399, 509], [399, 522], [399, 531]],
    r4:  [[407, 522], [409, 500], [415, 466], [357, 474], [357, 475]],
    r4m: [[351, 502], [338, 510]],
    r5:  [[348, 498], [361, 485], [360, 474], [364, 433], [362, 433]],
    r5m: [[343, 434], [327, 434]],
    r6:  [[342, 430], [363, 430], [398, 430], [419, 429]]
};

// ============================================================================
// HELPERS
// ============================================================================

function pauseCombatMode() {
    // Mettiamo in pausa i vari script di attacco noti per evitare distrazioni
    Orion.PauseScript('SoloFollowAndAttack');
    Orion.PauseScript('SoloFollowAndAttackSS');
    Orion.PauseScript('UseSpecialAbilities');
    Orion.PauseScript('UseSpecialAbilitiesSS');
    Orion.PauseScript('AutoArcheryAttack');
    Orion.PauseScript('AttackNearestEnemy');
    Orion.PauseScript('SOLOGENERAL');
    
    Orion.WarMode(0);
    Orion.CancelTarget();
}

function resumeCombatMode() {
    // Riattiviamo gli script di attacco e resettiamo gli ignore (SOLO) una volta dentro la stanza
    if (typeof SOLO === "function") SOLO(); 
    
    Orion.ResumeScript('SoloFollowAndAttack');
    Orion.ResumeScript('SoloFollowAndAttackSS');
    Orion.ResumeScript('UseSpecialAbilities');
    Orion.ResumeScript('UseSpecialAbilitiesSS');
    Orion.ResumeScript('AutoArcheryAttack');
    Orion.ResumeScript('AttackNearestEnemy');
    Orion.ResumeScript('SOLOGENERAL');
}

function walkPath(coords) {
    if (!coords || coords.length === 0) return;

    // Disattiva combattimento durante lo spostamento
    pauseCombatMode();

    var nearestIndex = 0;
    var minDistance = 10000;

    // Trova l'indice del punto più vicino a noi nel binario
    for (var j = 0; j < coords.length; j++) {
        var dist = Orion.GetDistance(coords[j][0], coords[j][1]);
        if (dist < minDistance) {
            minDistance = dist;
            nearestIndex = j;
        }
    }

    // Cammina partendo dal punto più vicino trovato fino alla fine della lista
    for (var i = nearestIndex; i < coords.length; i++) {
        Orion.WalkTo(coords[i][0], coords[i][1], Player.Z(), 1, 255, 1, 2, 5000);
        Orion.Wait(10);
    }
}

function forceStep(direction, steps) {
    pauseCombatMode(); // Sicurezza extra
    for (var i = 0; i < steps; i++) {
        Orion.Step(direction);
        Orion.Wait(80);
    }
}

function equipSlayer(listName) {
    if (currentDressList !== listName) {
        Orion.Print(65, "Dress Doom: " + listName);
        Orion.Dress(listName);
        Orion.Wait(80);
        currentDressList = listName;
    }
}

function getEnemy(range) {
    var mobs = Orion.FindTypeEx(
        targetGraphics,
        'any',
        'ground',
        targetFlags,
        range,
        targetNoto
    );

    if (!mobs || mobs.length === 0) {
        return null;
    }

    for (var i = 0; i < mobs.length; i++) {
        var mob = mobs[i];

        if (!mob) {
            continue;
        }

        if (typeof ignoredMobs !== 'undefined' && ignoredMobs[mob.Serial()]) {
            continue;
        }

        if (typeof isIgnoredSummon === "function" && isIgnoredSummon(mob)) {
            continue;
        }

        return mob;
    }

    return null;
}

function fightLogic(range, roomNum) {
    resumeCombatMode(); // Riattiva gli script di combattimento

    var roomClear = false;
    var emptyCheckStarted = false;
    var emptySince = 0;

    while (!Player.Dead() && !roomClear) {
        
        var enemy = getEnemy(range);

        if (enemy) {
            // Se vedo il nemico, resetto istantaneamente il timer di "stanza vuota"
            emptyCheckStarted = false;
            emptySince = 0;

            // Logica specifica (armi) per la Stanza 6 (Dark Father)
            if (roomNum === 6) {
                var enemiesNear = Orion.FindTypeEx(
                    'any',
                    'any',
                    'ground',
                    'live|ignoreself|ignorefriends',
                    2,
                    'gray|criminal|red|enemy|orange'
                );

                var validEnemiesNear = 0;

                for (var j = 0; j < enemiesNear.length; j++) {
                    var nearMob = enemiesNear[j];
                    var ignored = false;

                    if (typeof ignoredMobs !== 'undefined' && ignoredMobs[nearMob.Serial()]) {
                        ignored = true;
                    }

                    if (!ignored && typeof isIgnoredSummon === "function" && isIgnoredSummon(nearMob)) {
                        ignored = true;
                    }

                    if (!ignored) {
                        validEnemiesNear++;
                    }
                }

                var enemyGraphic = enemy.Graphic ? enemy.Graphic().toString().toLowerCase() : '';
                var enemyName = enemy.Name ? (enemy.Name() || '') : '';

                var isDarkFather =
                    enemyGraphic === '0x013e' ||
                    enemyName.indexOf("Dark Father") !== -1;

               if (validEnemiesNear > 1) {

    safeToggleDressWeapon('Dress_GenericArea');

    if (!Orion.AbilityStatus('Secondary')) {
        Orion.UseAbility('Secondary');
    }
} else if (isDarkFather) {

    safeToggleDressWeapon('Dress_DoomDarkFather');
}
            }

            Orion.Wait(150);

        } else {
            // --- CHECK STANDARD (Valido per TUTTE le stanze, compresa la 4) ---
            
            // Se non c'è il timer avviato, lo avviamo adesso
            if (!emptyCheckStarted) {
                emptySince = Orion.Now();
                emptyCheckStarted = true;
            }

            // Se sono passati 3000 millisecondi (3 secondi) netti da quando non vediamo nessuno
            if (Orion.Now() - emptySince >= 3000) {
                roomClear = true; // Stanza pulita, usciamo dal ciclo!
            } else {
                Orion.Wait(250); // Aspettiamo un quarto di secondo e ricontrolliamo
            }
        }
    }
}

function AutoDoomGauntlet(stanza, singleRun) {
    Orion.Print(89, '=== Avvio Doom Gauntlet ===');
    Orion.IgnoreReset();

    if (typeof GetCheckboxStatus === "function") {
        if (!GetCheckboxStatus("AutoDoomGauntlet")) {
            ToggleDoomGauntlet();
        }
    }

    var isSingle = (singleRun === true);

    Orion.Wait(50);

    while (!Player.Dead()) {

        if (stanza <= 1) {
            Orion.Print(65, ">> Esecuzione Stanza 1 - Darknight Creeper");

            safeToggleDressTalisman('Dress_TalismanUndead');
            Orion.Wait(150);
            safeToggleDressWeapon('Dress_DoomDarknightCreeper');

            walkPath(rails.r1);
            forceStep('East', 2);
            walkPath(rails.r1m);
            fightLogic(15, 1);
        }

        if (stanza <= 2) {
            Orion.Print(65, ">> Esecuzione Stanza 2 - Fleshrenderer");

            // Rimane talismano Undead
            safeToggleDressTalisman('Dress_TalismanUndead');
            Orion.Wait(150);
            safeToggleDressWeapon('Dress_DoomFleshrenderer');

            walkPath(rails.r2);
            forceStep('South', 4);
            walkPath(rails.r2m);
            fightLogic(15, 2);

            Orion.UseObject('0x40101F16');
        }

        if (stanza <= 3) {
            Orion.Print(65, ">> Esecuzione Stanza 3 - Impaler");

            safeToggleDressTalisman('Dress_TalismanDemon');
            Orion.Wait(150);
            safeToggleDressWeapon('Dress_DoomImpaler');

            walkPath(rails.r3);
            forceStep('South', 4);
            walkPath(rails.r3m);
            fightLogic(15, 3);
        }

        if (stanza <= 4) {
            Orion.Print(65, ">> Esecuzione Stanza 4 - Shadow Knight");

            safeToggleDressTalisman('Dress_TalismanUndead');
            Orion.Wait(150);
            safeToggleDressWeapon('Dress_DoomShadowKnight');

            walkPath(rails.r4);
            forceStep('West', 4);
            forceStep('South', 4);
            walkPath(rails.r4m);
            fightLogic(15, 4);
        }

        if (stanza <= 5) {
            Orion.Print(65, ">> Esecuzione Stanza 5 - Abyssmal Horror");

            safeToggleDressTalisman('Dress_TalismanDemon');
            Orion.Wait(150);
            safeToggleDressWeapon('Dress_DoomAbyssmalHorror');

            walkPath(rails.r5);
            forceStep('West', 4);
            walkPath(rails.r5m);
            fightLogic(15, 5);
        }

        if (stanza <= 6) {
            Orion.Print(65, ">> Stanza 6 - Dark Father");

            if (!Orion.ScriptRunning('doomBoneCutter')) {
                Orion.Print(65, ">> Attivazione doomBoneCutter...");
                Orion.Exec('doomBoneCutter', 'true');
                GUI();
            }

            safeToggleDressTalisman('Dress_TalismanDemon');
            Orion.Wait(150);
            safeToggleDressWeapon('Dress_DoomDarkFather');

            walkPath(rails.r6);
            fightLogic(18, 6);
        }

        if (isSingle) {
            Orion.Print(89, '=== Task terminato, ripristino DOOM principale ===');

            if (typeof ToggleDoomGauntlet === "function") {
                ToggleDoomGauntlet();
            }

            break;
        } else {
            stanza = 1;
            Orion.Print(55, '=== Giro finito, ricomincio dalla prima ===');
            Orion.Wait(1000);
        }
    }
}

var currentWeaponDress = "";
var currentTalismanDress = "";

function safeToggleDressWeapon(listName) {
    if (currentWeaponDress !== listName) {
        ToggleDressWeapon(listName);
        currentWeaponDress = listName;
    }
}

function safeToggleDressTalisman(listName) {
    if (currentTalismanDress !== listName) {
        ToggleDressTalisman(listName);
        currentTalismanDress = listName;
    }
}
// ============================================================================
// SCRIPT: Bone Scavenger & Combat Pro (Profile Integrated - Aggressive Combat)
// DESCRIZIONE: Sfrutta StartProfile() per attivare tutti i buff e le difese.
// Aggiunge: Movimento random turbo, targeting 18 tile, switch Primary/Secondary,
// loot ossa (0x0F80) e Bag of Sending automatica.
// FIX: Combattimento forzato "Sticky" per non smettere mai di attaccare.
// ============================================================================

// --- CONFIGURAZIONE ---
var bonesGraphic = '0x0F80'; 
var bagOfSendingSerial = '0x407F88C9'; 
var targetRange = 18; 
var targetFlags = 'ignoreself|ignorefriends|live|inlos|near'; 
var targetNoto = 'gray|criminal|red|enemy|orange'; 

function StartBoneScavenger() {
    Orion.Print(65, '--- Inizializzazione Profilo Sampire ---');
    
    // Inizializziamo il profilo usando la tua funzione originale
    StartProfile('BoneScavenger', null, null, false, false);
    
    Orion.Print(65, '--- Avvio Esplorazione e Loot Ossa ---');
    Orion.CancelTarget();
    Orion.IgnoreReset();
    
    while (!Player.Dead()) {
        // 0. Gestione Blood Oath (Sempre prioritaria)
        HandleBloodOath();

        // 1. Controllo Peso e Banca
        CheckWeightAndSend();

        // 2. Ricerca Nemico (Logica Champ 18 tile)
        var enemies = Orion.FindTypeEx('any', 'any', 'ground', targetFlags, targetRange, targetNoto);

        if (enemies.length > 0) {
            var target = enemies[0].Serial();
            Orion.Print(33, 'Bersaglio agganciato: ' + enemies[0].Name());
            
            // 3. Honor
            HonorTarget(target);
            
            // 4. Combattimento Dinamico (Sticky Attack)
            ExecuteCombat(target);
            
            // Pausa Loot 600ms per caricare le ossa
            Orion.Wait(600); 
        } else {
            // 5. Esplorazione Random ULTRA-VELOCE
            TurboRandomWander();
        }

        Orion.Wait(50); 
    }
}

// --- LOGICA DI COMBATTIMENTO FORZATA (NON SMETTE MAI) ---
function ExecuteCombat(serial) {
    var mob = Orion.FindObject(serial);
    if (!mob) return;

    // Primo attacco
    Orion.WarMode(true);
    Orion.Attack(serial);
    
    while (mob && !mob.Dead() && Orion.ObjectExists(serial)) {
        // --- CONTROLLO STICKY ATTACK ---
        // Se il client esce da WarMode o perde il last attack, forza di nuovo
        if (!Player.WarMode() || Orion.ClientLastAttack() !== serial) {
            Orion.Print(33, 'Riprovo attacco su: ' + mob.Name());
            Orion.WarMode(true);
            Orion.Attack(serial);
        }

        // Se appare Blood Oath durante il fight, gestiscilo e poi riprendi
        if (Orion.BuffExists('Blood Oath')) {
            HandleBloodOath();
            Orion.Attack(serial);
        }

        // Movimento verso il mob (Corsa)
        if (Orion.GetDistance(serial) > 1) {
            Orion.WalkTo(mob.X(), mob.Y(), mob.Z(), 1, 255, 1);
        }
        
        // --- SWITCH ABILITÀ DINAMICO ---
        var nearbyCount = Orion.FindType('any', 'any', 'ground', 'live|ignoreself', 2, targetNoto).length;
        if (nearbyCount > 1) {
            if (!Orion.AbilityStatus('Secondary')) Orion.UseAbility('Secondary', true);
        } else {
            if (!Orion.AbilityStatus('Primary')) Orion.UseAbility('Primary', true);
        }

        Orion.Wait(200); // Ridotto delay interno per maggiore reattività
        mob = Orion.FindObject(serial);
    }
    
    // Solo a mob morto resettiamo la WarMode per correre meglio
    Orion.WarMode(false);
}

// --- ESPLORAZIONE TURBO ---
function TurboRandomWander() {
    var offsetX = Orion.Random(31) - 15;
    var offsetY = Orion.Random(31) - 15;
    var destX = Player.X() + offsetX;
    var destY = Player.Y() + offsetY;
    
    Orion.Print(55, 'Esplorazione veloce...');
    // Corsa forzata (run=1)
    Orion.WalkTo(destX, destY, Player.Z(), 1, 255, 1, 1, 1200);
    Orion.Wait(100); 
}

// --- GESTIONE BANCA (Migliorata) ---
function CheckWeightAndSend() {
    Orion.GetStatus(Player.Serial());
    var currentWeight = Player.Weight();
    var maxWeight = Player.MaxWeight();

    if (currentWeight >= (maxWeight - 20)) {
        Orion.Print(33, 'Zaino pieno (' + currentWeight + '/' + maxWeight + ').');
        var foundBones = Orion.FindType(bonesGraphic, 'any', 'backpack', 'item', '', '', true);
        
        if (foundBones.length > 0) {
            var bag = Orion.FindObject(bagOfSendingSerial);
            if (bag) {
                Orion.Print(65, 'Spedisco ossa...');
                Orion.UseObject(bagOfSendingSerial);
                if (Orion.WaitForTarget(2500)) {
                    Orion.TargetObject(foundBones[0]);
                    Orion.Wait(1000); 
                }
            }
        }
    }
}

function HandleBloodOath() {
    if (!Orion.BuffExists('Blood Oath')) {
        return false;
    }

    Orion.Print(33, 'BLOOD OATH RILEVATO!');
    Orion.CharPrint(Player.Serial(), 33, '*BLOOD OATH RILEVATO!*');

    // Suono una sola volta quando viene rilevato
    Orion.PlayWav("C:\\Orion Launcher\\OA\\beep.wav");

    Orion.WarMode(false);
    Orion.CancelTarget();

    while (Orion.BuffExists('Blood Oath') && !Player.Dead()) {
    Orion.Wait(50);
        Orion.Cast('209');

        if (Orion.WaitForTarget(2000)) {
            Orion.TargetObject('self');
        }

        Orion.Wait(450);
    }

    Orion.CancelTarget();

    if (!Player.Dead()) {
        Orion.CharPrint(Player.Serial(), 65, '*BLOOD OATH RIMOSSO!*');
        Orion.Print(65, 'BLOOD OATH RIMOSSO!');
        Orion.WarMode(true);
    }

    return true;
}

function HonorTarget(serial) {
    Orion.CancelTarget();
    Orion.InvokeVirtue('Honor');
    Orion.WaitTargetObject(serial);
    Orion.Wait(50);
}

function StopBoneScavenger() {
    Orion.Terminate('StartBoneScavenger');
    Orion.WarMode(false);
    Orion.Print(33, 'Bone Scavenger FERMATO.');
}

// ============================================================================
// SCRIPT: Dragon Bell Farmer (Sampire)
// DESCRIZIONE: Staziona su una campana, la clicca per far spawnare un drago,
// lo uccide con logica "Sticky", loota le ossa e usa la Bag of Sending.
// FIX: Anti-spam con Cooldown e ritorno alla campana SOLO a drago morto.
// ============================================================================

// --- CONFIGURAZIONE ---
var bellSerial = '0x40144403'; 
var bellPos = { x: 417, y: 246, z: 23 };
var bonesGraphic = '0x0F80'; 
var bagOfSendingSerial = '0x407F88C9'; 
var targetRange = 20; // Aumentato a 20 per evitare il "tira e molla" ai bordi dello schermo
var targetFlags = 'ignoreself|ignorefriends|live|inlos|near'; 
var targetNoto = 'gray|criminal|red|enemy|orange'; 

// Frase esatta dal server per evitare spam
var msgAlreadySummoned = "The ferry man has already been summoned. There is no need to ring for him again.";
var lastClickTime = 0; // Variabile per gestire il cooldown dei click

function StartDragonFarmer() {
    Orion.Print(65, '--- Avvio Farmer Campana Drago ---');
    
    // Inizializziamo il profilo standard per buff/difese
    if (typeof StartProfile === 'function') {
        StartProfile('DragonFarmer', null, null, false, false);
    }
    
    Orion.IgnoreReset();
    
    while (!Player.Dead()) {
        // 1. Sopravvivenza (Blood Oath)
        HandleBloodOath();

        // 2. Controllo Peso e invio in Banca
        CheckWeightAndSend();

        // 3. Ricerca del Drago (Nemico) - Range ampio per non perderlo mai
        var enemies = Orion.FindTypeEx('any', 'any', 'ground', targetFlags, targetRange, targetNoto);
        
        if (enemies.length > 0) {
            var target = enemies[0].Serial();
            Orion.Print(33, 'Drago rilevato! Attacco in corso...');
            
            // Honor sul bersaglio
            HonorTarget(target);
            
            // Combattimento "Sticky" (Rimane in questo blocco finché il drago non muore)
            ExecuteCombat(target);
            
            // Dopo il combattimento, loot rapido delle ossa a terra
            LootBones();

            // Pulizia totale dopo il loot per prepararsi al prossimo spawn
            Orion.ClearJournal();
            lastClickTime = 0; // Resettiamo il cooldown per poter cliccare subito dopo la morte
            
            // IL DRAGO E' MORTO E LOOTATO: ora possiamo tornare alla campana
            ReturnToBell();
        } else {
            // 4. Nessun Drago in vista. 
            // Se per caso ci siamo allontanati troppo (es. respawn), torniamo alla campana.
            // Uso > 2 così non "balla" se è a 1 tile di distanza.
            if (Orion.GetDistance(bellPos.x, bellPos.y) > 2) {
                ReturnToBell();
            } else {
                // SIAMO ALLA CAMPANA: LOGICA ANTI-SPAM
                var currentTime = Orion.Now();
                
                // Se abbiamo già letto il messaggio di "già evocato", aspettiamo e basta
                if (Orion.InJournal(msgAlreadySummoned)) {
                    Orion.Print(33, 'Drago evocato ma non ancora visibile. Attendo spawn...');
                    Orion.Wait(2000); // Pausa, poi il loop riparte e se il drago è comparso lo attacca
                    continue;
                }

                // Cooldown: Non cliccare la campana più di una volta ogni 7 secondi
                if (currentTime - lastClickTime > 7000) {
                    Orion.ClearJournal(); // Puliamo prima del click
                    Orion.Print(65, 'Attivazione campana...');
                    Orion.UseObject(bellSerial);
                    lastClickTime = currentTime;
                    
                    Orion.Wait(1500); // Diamo tempo al server di rispondere e scrivere nel journal
                    
                    if (Orion.InJournal(msgAlreadySummoned)) {
                        Orion.Print(33, 'Server conferma: Drago già presente.');
                    }
                } else {
                    // Se siamo nel cooldown, aspettiamo semplicemente senza inviare pacchetti
                    Orion.Wait(500);
                }
            }
        }

        Orion.Wait(200); 
    }
}

// --- FUNZIONE DEDICATA PER TORNARE ALLA CAMPANA ---
function ReturnToBell() {
    if (Orion.GetDistance(bellPos.x, bellPos.y) > 2) {
        Orion.Print(55, 'Torno alla campana...');
        // WalkTo(x, y, z, distanceXY, distanceZ, run, openDoor, timeout)
        Orion.WalkTo(bellPos.x, bellPos.y, bellPos.z, 1, 255, 1, 2, 5000);
        Orion.Wait(500);
    }
}

// --- LOGICA DI COMBATTIMENTO FORZATA (STICKY) ---
function ExecuteCombat(serial) {
    var mob = Orion.FindObject(serial);
    if (!mob) return;

    Orion.WarMode(true);
    Orion.Attack(serial);
    
    while (mob && !mob.Dead() && Orion.ObjectExists(serial)) {
        if (!Player.WarMode() || Orion.ClientLastAttack() !== serial) {
            Orion.WarMode(true);
            Orion.Attack(serial);
        }

        HandleBloodOath();

        if (Orion.GetDistance(serial) > 1) {
            // Aggiunto timeout di 500ms per evitare loop di ricalcolo (stuttering)
            Orion.WalkTo(mob.X(), mob.Y(), mob.Z(), 1, 255, 1, 2, 500);
        }
        
        var nearbyCount = Orion.FindType('any', 'any', 'ground', 'live|ignoreself', 2, targetNoto).length;
        if (nearbyCount > 1) {
            if (!Orion.AbilityStatus('Secondary')) Orion.UseAbility('Secondary', true);
        } else {
            if (!Orion.AbilityStatus('Primary')) Orion.UseAbility('Primary', true);
        }

        Orion.Wait(250);
        mob = Orion.FindObject(serial);
    }
    
    Orion.WarMode(false);
    Orion.Print(65, 'Drago eliminato.');
}

// --- RACCOLTA OSSA ---
function LootBones() {
    Orion.Print(55, 'Raccolta ossa...');
    var bones = Orion.FindType(bonesGraphic, 'any', 'ground', 'item', 3);
    while (bones.length > 0) {
        Orion.MoveItem(bones[0], 0, 'backpack');
        Orion.Wait(600);
        bones = Orion.FindType(bonesGraphic, 'any', 'ground', 'item', 3);
    }
}

// --- GESTIONE BANCA (Bag of Sending) ---
function CheckWeightAndSend() {
    if (Player.Weight() >= (Player.MaxWeight() - 30)) {
        Orion.Print(33, 'Zaino quasi pieno. Invio ossa in banca...');
        
        var bonesInPack = Orion.FindType(bonesGraphic, 'any', 'backpack');
        if (bonesInPack.length > 0) {
            var bag = Orion.FindObject(bagOfSendingSerial);
            if (bag) {
                Orion.UseObject(bagOfSendingSerial);
                if (Orion.WaitForTarget(2000)) {
                    Orion.TargetObject(bonesInPack[0]);
                    Orion.Wait(1000);
                    Orion.Print(65, 'Ossa inviate correttamente.');
                }
            } else {
                Orion.Print(33, 'ERRORE: Bag of Sending non trovata!');
            }
        }
    }
}



function HonorTarget(serial) {
    if (serial) {
        Orion.CancelTarget();
        Orion.InvokeVirtue('Honor');
        Orion.WaitTargetObject(serial);
        Orion.Wait(100);
    }
}

function StopDragonFarmer() {
    Orion.Terminate('StartDragonFarmer');
    Orion.WarMode(false);
    Orion.Print(33, 'Script Fermato.');
}

/**
 * Script semplificato per fusione oggetti e uova nel calderone.
 * Se un oggetto non viene smeltato (appare un gump o rimane nel backpack), 
 * viene ignorato e lo script passa al successivo.
 * L'utente gestisce manualmente i Gump.
 */

const CALDERONE_SERIAL = '0x407AA952';
const COLORE_GENERICO = '0x0AE0';
const GRAFICA_SABBIA = '0xA3E8';
const NOME_UOVA_PARZIALE = 'Umbrascale Dragon Egg';

// Lista seriali da ignorare se non smeltabili
var ignoreList = [];

function SmeltAndStack() {
    Orion.Print(68, '--- Inizio Ciclo Smelting ---');
    ignoreList = []; 

    while (!Player.Dead()) {
        var itemToSmelt = null;

        // --- 1. RICERCA PER COLORE (Armature, Scudi, ecc.) ---
        var colorItems = Orion.FindType('any', COLORE_GENERICO, 'backpack');
        if (colorItems.length > 0) {
            for (var i = 0; i < colorItems.length; i++) {
                if (ignoreList.indexOf(colorItems[i]) === -1) {
                    itemToSmelt = colorItems[i];
                    break;
                }
            }
        }

        // --- 2. RICERCA PER NOME (Uova varianti Umbrascale) ---
        if (!itemToSmelt) {
            var allInBackpack = Orion.FindType('any', 'any', 'backpack');
            for (var i = 0; i < allInBackpack.length; i++) {
                var serial = allInBackpack[i];
                if (ignoreList.indexOf(serial) !== -1) continue;

                var obj = Orion.FindObject(serial);
                if (obj && obj.Exists()) {
                    var props = obj.Properties();
                    if (props && props.indexOf(NOME_UOVA_PARZIALE) !== -1) {
                        itemToSmelt = serial;
                        break;
                    }
                }
            }
        }

        // --- 3. AZIONE DI SMELTING ---
        if (itemToSmelt) {
            Orion.Print(55, 'Provo a smeltare: ' + itemToSmelt);
            
            Orion.UseObject(CALDERONE_SERIAL);
            
            if (Orion.WaitForTarget(2000)) {
                Orion.TargetObject(itemToSmelt);
                // Attesa per permettere al server di processare l'azione
                Orion.Wait(1000); 
            }
            
            // Verifica se l'oggetto è ancora presente
            // Se esiste ancora, significa che non è stato smeltato (protetto o errore)
            if (Orion.FindObject(itemToSmelt)) {
                Orion.Print(33, 'Oggetto non smeltato. Lo ignoro e procedo.');
                ignoreList.push(itemToSmelt);
            }
            
            Orion.Wait(100);
        } else {
            // --- 4. FINE OGGETTI: ACCUMULO SABBIA ---
            Orion.Print(33, 'Nessun altro oggetto trovato. Raggruppo la sabbia...');
            StackSand();
            break; 
        }
    }
    
    Orion.Print(68, '--- Operazione Completata ---');
}

function StackSand() {
    var sandPiles = Orion.FindType(GRAFICA_SABBIA, 'any', 'backpack');
    
    if (sandPiles.length < 2) {
        Orion.Print(25, 'Meno di 2 pile di sabbia trovate. Nulla da unire.');
        return;
    }

    var masterPile = sandPiles[0];
    
    for (var i = 1; i < sandPiles.length; i++) {
        var currentPile = sandPiles[i];
        if (currentPile !== masterPile && Orion.FindObject(currentPile)) {
            Orion.MoveItem(currentPile, 0, masterPile);
            Orion.Wait(600);
        }
    }
    
    Orion.Print(25, 'Sabbia raggruppata.');
}

function StartSmelting() {
    Orion.Exec('SmeltAndStack');
}

function autoRemoveBloodOath() {
    while (true) {
        if (Orion.BuffExists('Blood Oath')) {
	Orion.Cast('209');
	if (Orion.WaitForTarget(1000))
		Orion.TargetObject('self');
		Orion.Wait(150);
        }
    }
}

// --- VARIABILI GLOBALI ---
// Lista persistente dei GRAPHIC da considerare prioritari
if (!Shared.GetVar('idenemyevento_list')) {
    Shared.AddVar('idenemyevento_list', '');
}

// Stato runtime (non persistente) per seriali gia' marcati/aggrati
var _eventPrimaryMarked = {};     // serial -> true
var _eventSecondaryMarked = {};   // serial -> true
var _eventAggroDone = {};         // serial -> true
var _eventHighlightDone = {};     // serial -> true

// Colore highlight arancione
var EVENT_HIGHLIGHT_COLOR = '2775'; // arancione, puoi cambiarlo se vuoi


// Funzione helper per ottenere la lista come array
function GetEnemyList() {
    var raw = Shared.GetVar('idenemyevento_list');
    return raw ? raw.split('|') : [];
}

// Funzione helper per salvare l'array come stringa
function SaveEnemyList(arr) {
    Shared.AddVar('idenemyevento_list', arr.join('|'));
}

// Pulisce gli stati runtime dei seriali che non esistono piu'
function CleanupRuntimeState() {
    var maps = [_eventPrimaryMarked, _eventSecondaryMarked, _eventAggroDone, _eventHighlightDone];
    for (var m = 0; m < maps.length; m++) {
        for (var serial in maps[m]) {
            var obj = Orion.FindObject(serial);
            if (!obj || !obj.Exists() || obj.Dead()) {
                delete maps[m][serial];
            }
        }
    }
}

// Funzione per aggiungere il GRAPHIC del nemico alla lista
function AddEnemyToEventList() {
    Orion.Print(55, 'Seleziona il nemico da aggiungere ai filtri Evento...');

    Orion.AddObject('temp_target');
    while (Orion.HaveTarget()) {
        Orion.Wait(50);
    }

    var targetObj = Orion.FindObject('temp_target');
    if (targetObj) {
        var graphic = targetObj.Graphic();

        if (graphic) {
            var currentList = GetEnemyList();
            if (currentList.indexOf(graphic) === -1) {
                currentList.push(graphic);
                SaveEnemyList(currentList);
                Orion.Print(66, 'Tipo aggiunto: ' + graphic + ' (Filtro Attivo)');
            } else {
                Orion.Print(33, 'Questo tipo di nemico e gia presente.');
            }
        }
    }
}

// Funzione per svuotare la lista
function ClearEventList() {
    Shared.AddVar('idenemyevento_list', '');
    _eventPrimaryMarked = {};
    _eventSecondaryMarked = {};
    _eventAggroDone = {};
    _eventHighlightDone = {};
    Orion.Print(33, 'Filtri rimossi. Lista svuotata.');
}

// Ordina i seriali per distanza reale
function SortByDistance(serials) {
    serials.sort(function (a, b) {
        var oa = Orion.FindObject(a);
        var ob = Orion.FindObject(b);

        var da = 999;
        var db = 999;

        if (oa && oa.Exists()) da = oa.Distance();
        if (ob && ob.Exists()) db = ob.Distance();

        return da - db;
    });

    return serials;
}

// Evidenzia il mob una sola volta in arancione
function HighlightAggroMobOnce(serial) {
    if (!_eventHighlightDone[serial]) {
        Orion.AddHighlightCharacter(serial, EVENT_HIGHLIGHT_COLOR, true);
        _eventHighlightDone[serial] = true;
    }
}

// Marca il target principale 1 sola volta
function MarkPrimaryTargetOnce(serial) {
    if (!_eventPrimaryMarked[serial]) {
        Orion.CharPrint(serial, 48, '*TARGET*');
        _eventPrimaryMarked[serial] = true;
    }
}

// Marca i target aggrati 1 sola volta
function MarkAggroOnce(serial) {
    if (!_eventSecondaryMarked[serial]) {
        Orion.CharPrint(serial, 63, '*AGGRATO*'); // hue arancione circa
        _eventSecondaryMarked[serial] = true;
    }
}

// Esegue un singolo ping di aggro sul mob, 1 sola volta
function AggroMobOnce(serial, isPrimary) {
    if (_eventAggroDone[serial]) {
        return;
    }

    HighlightAggroMobOnce(serial);

    if (isPrimary) {
        MarkPrimaryTargetOnce(serial);
    } else {
        MarkAggroOnce(serial);
    }

    Orion.Attack(serial);
    Orion.Wait(80);

    _eventAggroDone[serial] = true;
}

// Funzione principale di ricerca/aggro/navigazione
function HandleAggroAndNavigation() {
    CleanupRuntimeState();

    var currentList = GetEnemyList();
    if (!currentList || currentList.length === 0) {
        return false;
    }

    var range = 10;
    var mobs = [];
    var alreadyAdded = {};

    // Cerca separatamente ogni graphic presente nella lista
    for (var t = 0; t < currentList.length; t++) {
        var graphic = currentList[t];
        if (!graphic || graphic === '') {
            continue;
        }

        var found = Orion.FindTypeEx(
            graphic,
            'any',
            'ground',
            'mobile|live|ignorefriends|inlos',
            range,
            'gray|red|orange'
        );

        if (found && found.length) {
            for (var i = 0; i < found.length; i++) {
                var mob = found[i];
                var serial = mob.Serial();

                if (!alreadyAdded[serial]) {
                    alreadyAdded[serial] = true;
                    mobs.push(serial);
                }
            }
        }
    }

    if (mobs.length === 0) {
        return false;
    }

    mobs = SortByDistance(mobs);

    var primarySerial = mobs[0];
    var primaryObj = Orion.FindObject(primarySerial);

    if (!primaryObj || !primaryObj.Exists() || primaryObj.Dead()) {
        return false;
    }

    // evidenzia e attacca il principale
    HighlightAggroMobOnce(primarySerial);
    AggroMobOnce(primarySerial, true);

    // aggra tutti gli altri mob della lista nel range,
    // tranne quelli con Graphic 0x003B
    for (var j = 1; j < mobs.length; j++) {
        var serial2 = mobs[j];
        var obj2 = Orion.FindObject(serial2);

        if (!obj2 || !obj2.Exists() || obj2.Dead() || obj2.Distance() > range) {
            continue;
        }

        // Il mob 0x003B puo' essere target principale,
        // ma NON viene aggrato come secondario.
        if (obj2.Graphic() == '0x003B') {
            continue;
        }

        HighlightAggroMobOnce(serial2);
        AggroMobOnce(serial2, false);
    }

    // rimetti come ultimo attacco il principale
    if (Orion.ClientLastAttack() !== primarySerial) {
        Orion.Attack(primarySerial);
        Orion.Wait(50);
    }

    // vai verso il principale
    if (primaryObj.Distance() > 1) {
        Orion.WalkTo(primaryObj.X(), primaryObj.Y(), primaryObj.Z(), 1, 5, 1, 1);
    }

    return true;
}
// --- LOGICA EVENTOVOID ---
function EventoVoid() {
    Orion.Print(66, '--- Evento Void: Aggro Prioritario Attivo ---');

    while (!Player.Dead()) {
        if (Orion.GetGlobal('StopAllScripts') === 'true') {
            Orion.StopWalking();
            return;
        }

        // Priorita' assoluta ai mob filtrati
        HandleAggroAndNavigation();

        Orion.Wait(100);
    }
}

function CheckObjectColorNumber() {
    Orion.Print(55, 'Seleziona oggetto o mob per leggere il colore...');

    Orion.AddObject('check_color_target');

    while (Orion.HaveTarget()) {
        Orion.Wait(50);
    }

    var obj = Orion.FindObject('check_color_target');

    if (!obj) {
        Orion.Print(33, 'Nessun oggetto selezionato.');
        return;
    }

    var colorHex = obj.Color();
    var colorDec = parseInt(colorHex, 16);

    Orion.Print(66, 'Name: ' + obj.Name());
    Orion.Print(66, 'Serial: ' + obj.Serial());
    Orion.Print(66, 'Graphic: ' + obj.Graphic());
    Orion.Print(66, 'Color Hex: ' + colorHex);
    Orion.Print(66, 'Color Dec: ' + colorDec);
}
function AttackSelectedEnemy() {
    var targetSerial = Orion.GetGlobal('LastEnemySerial');

    if (!targetSerial || !Orion.ObjectExists(targetSerial)) {
        Orion.CharPrint(Player.Serial(), 65, "Nessun nemico selezionato o non valido!");
        return;
    }

    Orion.Attack(targetSerial);
    Orion.CharPrint(targetSerial, 44, "⚔️ Attacco: " + Orion.RequestName(targetSerial));
}

function ShowKarmaFama()
{
    Orion.ClearJournal();

    Orion.Say('[premium');

    if (Orion.WaitForGump(1000))
    {
        var gump0 = Orion.GetGump('last');

        if ((gump0 !== null) && (!gump0.Replayed()) && (gump0.ID() === '0x5CB83289'))
        {
            gump0.Select(Orion.CreateGumpHook(3));
            Orion.Wait(100);
        }
    }

    var fame = '';
    var karma = '';

    var journalLine = Orion.InJournal('Fame');

    if (journalLine)
    {
        var text = '';

        // Prova a leggere il testo del journal in vari modi, a seconda della versione Orion
        if (journalLine.Text)
        {
            text = journalLine.Text();
        }
        else if (journalLine.Message)
        {
            text = journalLine.Message();
        }
        else
        {
            text = '' + journalLine;
        }

        Orion.Print(65, 'Fame/Karma: ' + text);

        var match = text.match(/Fame\s*=\s*([0-9]+)\s+Karma\s*=\s*([0-9]+)/i);

        if (match)
        {
            fame = match[1];
            karma = match[2];

            Orion.CharPrint(Player.Serial(), 33, '*FAMA* : ' + fame);
            Orion.Wait(150);
            Orion.CharPrint(Player.Serial(), 22, '*KARMA* : ' + karma);
        }
        else
        {
            Orion.CharPrint(Player.Serial(), 33, '*Formato Fame/Karma non letto*');
            Orion.Print(33, 'Testo ricevuto: ' + text);
        }
    }
    else
    {
        Orion.CharPrint(Player.Serial(), 33, '*Fame/Karma non trovati nel journal*');
    }

    Orion.Wait(100);

    var gump1 = Orion.GetGump('last');

    if (gump1 !== null)
    {
        gump1.Close();
    }
}

