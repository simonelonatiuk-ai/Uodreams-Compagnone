// UODREAMS COMPAGNONE 2026 - GUI / interaction layer
var targetGraphics = 'any';
var targetFlags = 'ignoreself|ignorefriends|live|inlos|near';
var targetRange = 12;
var targetNoto = 'gray|criminal|red|enemy|orange';

var ignoredMobs = {};
var isSendingGold = false;

var LAYOUT = {
    width:       12,
    gridUnit:    35,
    offsetX:    -75,
    offsetY:     200,
    headerY:     45,
    tabSpacing:  80,
    rowStep:     30,
    sectionGap:  40
};

var NAV = {
    title:    { text: '*UODREAMS COMPAGNONE 2.6*', offsetX: 120, color: 89 },
    tabs:     ['config', 'sampire', 'champ', 'misc', 'dress'],
    positions: [20, 100, 180, 260, 340],
    config:  { id: 1024, icon: 0x15CD, tip: 'Config Menu' },
    sampire: { id: 1015, icon: 0x15D3, tip: 'Sampire Menu' },
    champ:   { id: 1016, icon: 0x15D1, tip: 'Champ Selector Menu' },
    misc:    { id: 1018, icon: 0x15C0, tip: 'Miscellaneous Menu' },
    dress:   { id: 1019, icon: 0x15C9, tip: 'Dress Menu' }
};

function DrawNav(g, activeTab) {
    var ox = LAYOUT.offsetX;
    var oy = LAYOUT.offsetY;
    g.AddText(ox + NAV.title.offsetX, oy + 10, NAV.title.color, NAV.title.text);
    var y = oy + LAYOUT.headerY;
    for (var i = 0; i < NAV.tabs.length; i++) {
        var t = NAV[NAV.tabs[i]];
        var isActive = (NAV.tabs[i] === activeTab);
        g.AddButton(isActive ? 1017 : t.id, ox + NAV.positions[i], y, t.icon, t.icon, t.icon, isActive ? '66' : '');
        g.AddTooltip(isActive ? 'Collapse Menu' : t.tip);
    }
}

function BeginTab(selector) {
    Shared.AddVar('selector', selector);
    Orion.Wait(100);
    var g = Orion.CreateCustomGump(101099);
    g.Clear();
    g.SetCallback('OnClick');
    return g;
}

function DrawFrame(g, height) {
    var w = LAYOUT.width, u = LAYOUT.gridUnit;
    var ox = LAYOUT.offsetX, oy = LAYOUT.offsetY;
    for (var y = 0; y < height; ++y) {
        for (var x = 0; x < w; ++x) {
            var dx = ox + x * u, dy = oy + y * u;
            if      (y === 0 && x === 0)                      g.AddGumpPic(dx, dy, 0x9C40);
            else if (x === 0 && y === height - 1)             g.AddGumpPic(dx, dy, 0x9C46);
            else if (x === 0 && y > 0 && y < height - 1)     g.AddGumpPic(dx, dy, 0x9C43);
            else if (x === w - 1 && y > 0 && y < height - 1) g.AddGumpPic(dx, dy, 0x9C45);
            else if (y === height - 1 && x === w - 1)         g.AddGumpPic(dx, dy, 0x9C48);
            else if (y === 0 && x === w - 1)                  g.AddGumpPic(dx, dy, 0x9C42);
            else if (y === 0 && x > 0 && x < w - 1)          g.AddGumpPic(dx, dy, 0x9C41);
            else if (y === height - 1 && x > 0 && x < w - 1) g.AddGumpPic(dx, dy, 0x9C47);
            else                                               g.AddGumpPic(dx, dy, 0x9C44);
        }
    }
    g.AddCheckerTrans(ox, oy, w * u, height * u);
}

var PLAYER_CONFIG = { version: 1, character: '', objects: {}, dress_lists: { compagnone: [], luck: [] } };

// Read-only disk load — does NOT restore Orion aliases. Use before any modify+persist
// to guard against JS context resets wiping PLAYER_CONFIG between button presses.
function PlayerConfig_ReadDisk_() {
    var f = Orion.NewFile();
    if (!f || !f.Open(PlayerConfig_Path(), true)) return;
    var raw = f.ReadAll();
    f.Close();
    if (!raw) return;
    try {
        var p = JSON.parse(raw);
        if (p && p.objects) PLAYER_CONFIG = p;
    } catch (e) {}
    if (!PLAYER_CONFIG.dress_lists)            PLAYER_CONFIG.dress_lists = {};
    if (!PLAYER_CONFIG.dress_lists.compagnone) PLAYER_CONFIG.dress_lists.compagnone = [];
    if (!PLAYER_CONFIG.dress_lists.luck)       PLAYER_CONFIG.dress_lists.luck = [];
}

function PlayerConfig_Path() {
    var dir = Orion.CurrentScriptDirPath() || '';
    dir = dir.replace(/\\/g, '/');
    while (dir.length > 0 && dir.charAt(dir.length - 1) === '/') {
        dir = dir.substr(0, dir.length - 1);
    }
    var who = (Player.Name && Player.Name()) ? Player.Name() : 'unknown';
    return dir + '/compagnone_config_' + who + '.json';
}

function PlayerConfig_Load() {
    PLAYER_CONFIG = { version: 1, character: Player.Name(), objects: {}, dress_lists: { compagnone: [], luck: [] } };
    var path = PlayerConfig_Path();
    var f = Orion.NewFile();
    if (!f) return;
    if (!f.Open(path, true)) return;
    var raw = f.ReadAll();
    f.Close();
    if (!raw) return;
    try {
        var parsed = JSON.parse(raw);
        if (parsed && parsed.objects) PLAYER_CONFIG = parsed;
    } catch (e) {
        Orion.CharPrint(Player.Serial(), 33, 'Config JSON corrotto: ' + e);
        return;
    }
    if (!PLAYER_CONFIG.dress_lists)             PLAYER_CONFIG.dress_lists = {};
    if (!PLAYER_CONFIG.dress_lists.compagnone)  PLAYER_CONFIG.dress_lists.compagnone = [];
    if (!PLAYER_CONFIG.dress_lists.luck)        PLAYER_CONFIG.dress_lists.luck = [];
    var aliases = PLAYER_CONFIG.objects;
    for (var alias in aliases) {
        if (!aliases.hasOwnProperty(alias)) continue;
        var entry = aliases[alias];
        if (!entry || !entry.serial) continue;
        Orion.AddObject(alias, entry.serial);
        if (entry.name) Shared.AddVar(alias + '_name', entry.name);
    }
}

function PlayerConfig_Persist() {
    var path = PlayerConfig_Path();
    PLAYER_CONFIG.character = Player.Name() || '';

    var existing = Orion.NewFile();
    if (existing && existing.Open(path, true)) {
        existing.Remove();
    }

    var fresh = Orion.NewFile();
    if (!fresh) {
        Orion.CharPrint(Player.Serial(), 33, 'Config: Orion.NewFile() ha restituito null');
        return false;
    }
    if (!fresh.Open(path)) {
        Orion.CharPrint(Player.Serial(), 33, 'Config: Open fallito su ' + path);
        return false;
    }
    var serialized;
    try {
        serialized = JSON.stringify(PLAYER_CONFIG, null, 2);
    } catch (e) {
        Orion.CharPrint(Player.Serial(), 33, 'Config: JSON.stringify ha fallito: ' + e);
        fresh.Close();
        return false;
    }
    if (fresh.WriteLine) fresh.WriteLine(serialized);
    else                 fresh.Write(serialized);
    fresh.Close();
    Orion.CharPrint(Player.Serial(), 65, 'Config salvata (' + PlayerConfig_Count() + ') -> ' + path);
    return true;
}

function PlayerConfig_SaveObject(alias, serial, displayName) {
    PlayerConfig_ReadDisk_();
    if (!PLAYER_CONFIG.objects) PLAYER_CONFIG.objects = {};
    var serialStr = (typeof serial === 'string') ? serial : ('0x' + serial.toString(16).toUpperCase());
    PLAYER_CONFIG.objects[alias] = { serial: serialStr, name: displayName || '' };
    PlayerConfig_Persist();
}

function PlayerConfig_RemoveObject(alias) {
    PlayerConfig_ReadDisk_();
    if (PLAYER_CONFIG.objects && PLAYER_CONFIG.objects.hasOwnProperty(alias)) {
        delete PLAYER_CONFIG.objects[alias];
        PlayerConfig_Persist();
    }
}

function PlayerConfig_Reset() {
    PLAYER_CONFIG = { version: 1, character: Player.Name(), objects: {}, dress_lists: { compagnone: [], luck: [] } };
    var f = Orion.NewFile();
    if (f.Open(PlayerConfig_Path(), true)) f.Remove();
}

function PlayerConfig_Count() {
    var n = 0;
    if (PLAYER_CONFIG.objects) {
        for (var k in PLAYER_CONFIG.objects) if (PLAYER_CONFIG.objects.hasOwnProperty(k)) n++;
    }
    if (PLAYER_CONFIG.dress_lists) {
        for (var dl in PLAYER_CONFIG.dress_lists) {
            if (!PLAYER_CONFIG.dress_lists.hasOwnProperty(dl)) continue;
            var list = PLAYER_CONFIG.dress_lists[dl];
            if (list && list.length) n += list.length;
        }
    }
    return n;
}

var DRESS_LAYERS = [
    'HelmHat', 'Necklace', 'Earrings', 'Cloak', 'Robe',
    'OuterTorso', 'InnerTorso', 'Shirt', 'Pants', 'OuterLegs', 'Skirt',
    'Sash', 'Waist', 'Gloves', 'Bracelet', 'Ring',
    'BootsArmor', 'BootsCommon', 'Talisman', 'Tattoo'
];

function PlayerConfig_CaptureDress() {
    var entries = [];
    for (var i = 0; i < DRESS_LAYERS.length; i++) {
        var obj = Orion.ObjAtLayer(DRESS_LAYERS[i]);
        if (obj && obj.Serial) {
            entries.push({
                layer:  DRESS_LAYERS[i],
                serial: obj.Serial(),
                name:   obj.Name ? (obj.Name() || '') : ''
            });
        }
    }
    return entries;
}

function PlayerConfig_SaveDress(listName) {
    PlayerConfig_ReadDisk_();
    var captured = PlayerConfig_CaptureDress();
    PLAYER_CONFIG.dress_lists[listName] = captured;
    if (PlayerConfig_Persist()) {
        Orion.CharPrint(Player.Serial(), 65, 'Dress "' + listName + '" -> ' + captured.length + ' pezzi nel JSON');
    }
}

function PlayerConfig_SyncDressListsToOrion() {
    if (!PLAYER_CONFIG.dress_lists) return;
    for (var name in PLAYER_CONFIG.dress_lists) {
        if (!PLAYER_CONFIG.dress_lists.hasOwnProperty(name)) continue;
        var entries = PLAYER_CONFIG.dress_lists[name];
        if (!entries || !entries.length) continue;
        var serials = [];
        for (var i = 0; i < entries.length; i++) {
            if (entries[i] && entries[i].serial) serials.push(entries[i].serial);
        }
        if (serials.length && Orion.SetDressList) {
            try { Orion.SetDressList(name, serials); } catch (e) {}
        }
    }
}

function Autostart() {
    var retries = 0;
    while ((!Player.Name || !Player.Name()) && retries < 50) {
        Orion.Wait(200);
        retries++;
    }
    PlayerConfig_Load();
    PlayerConfig_SyncDressListsToOrion();
    GUIConfig();
}

function GUIConfig() {
    PlayerConfig_ReadDisk_();
    // Snapshot state into SharedVars BEFORE BeginTab's Orion.Wait(100) can reset JS context
    var dl = PLAYER_CONFIG && PLAYER_CONFIG.dress_lists;
    Shared.AddVar('cfg_hasGen',   dl && dl.compagnone && dl.compagnone.length > 0 ? '1' : '0');
    Shared.AddVar('cfg_hasLuck',  dl && dl.luck       && dl.luck.length       > 0 ? '1' : '0');
    Shared.AddVar('cfg_hasKnife', Orion.FindObject('bone_knife')    ? '1' : '0');
    Shared.AddVar('cfg_hasCasa',  Orion.FindObject('runebook_casa') ? '1' : '0');
    Shared.AddVar('cfg_hasLuna',  Orion.FindObject('runebook_luna') ? '1' : '0');
    Shared.AddVar('cfg_hasMount', Orion.ScriptRunning('autoMount')  ? '1' : '0');
    var g = BeginTab(0);
    // Read back from SharedVars — these survive the Wait inside BeginTab
    var checked  = Shared.GetVar('check_done') === '1';
    var hasGen   = Shared.GetVar('cfg_hasGen')   === '1';
    var hasLuck  = Shared.GetVar('cfg_hasLuck')  === '1';
    var hasKnife = Shared.GetVar('cfg_hasKnife') === '1';
    var hasCasa  = Shared.GetVar('cfg_hasCasa')  === '1';
    var hasLuna  = Shared.GetVar('cfg_hasLuna')  === '1';
    var hasMount = Shared.GetVar('cfg_hasMount') === '1';
    var offsetX = LAYOUT.offsetX;
    var offsetY = LAYOUT.offsetY;
    DrawFrame(g, 12);
    DrawNav(g, 'config');
    g.AddText(offsetX + 138, offsetY + 120, 53, '*CHARACTER CONFIG*');
    var rowY = offsetY + 160;
    var sx = offsetX + 220;
    g.AddText(offsetX + 30, rowY, 65, 'Personaggio:');
    g.AddText(offsetX + 140, rowY, 53, Player.Name() || '(sconosciuto)');
    rowY += LAYOUT.rowStep;
    g.AddButton(6003, offsetX + 30, rowY + 2, 0x2716, 0x2716, 0x2716, '');
    g.AddTooltip('Ricarica config dal disco');
    g.AddText(offsetX + 60, rowY, 65, 'Reload from disk');
    g.AddButton(6020, offsetX + 178, rowY + 2, 0x04B9, 0x04BA, 0x04B9, '');
    g.AddTooltip('Verifica stato items');
    g.AddText(offsetX + 200, rowY, checked ? 65 : 53, 'Verifica');
    rowY += LAYOUT.rowStep;
    g.AddButton(5114, offsetX + 30, rowY + 4, 0x2716, 0x2716, 0x2716, '');
    g.AddTooltip('Salva equip attuale come dress compagnone');
    g.AddText(offsetX + 60, rowY, 65, 'Salva equip Generico');
    if (checked) { g.AddText(sx, rowY, hasGen ? 53 : 0, hasGen ? 'X' : '0'); }
    g.AddButton(5115, sx + 20, rowY + 2, 0x04B9, 0x04BA, 0x04B9, '');
    g.AddTooltip('Equippa dress compagnone');
    rowY += LAYOUT.rowStep;
    g.AddButton(5116, offsetX + 30, rowY + 4, 0x2716, 0x2716, 0x2716, '');
    g.AddTooltip('Salva equip attuale come dress luck');
    g.AddText(offsetX + 60, rowY, 65, 'Salva equip Luck');
    if (checked) { g.AddText(sx, rowY, hasLuck ? 53 : 0, hasLuck ? 'X' : '0'); }
    g.AddButton(5117, sx + 20, rowY + 2, 0x04B9, 0x04BA, 0x04B9, '');
    g.AddTooltip('Equippa dress luck');
    rowY += LAYOUT.rowStep;
    g.AddButton(1020, offsetX + 30, rowY + 4, 0x2716, 0x2716, 0x2716, '');
    g.AddTooltip('Seleziona o resetta Coltello BoneCutter');
    g.AddText(offsetX + 60, rowY, 65, 'BoneCutter DOOM');
    if (checked) { g.AddText(sx, rowY, hasKnife ? 53 : 0, hasKnife ? 'X' : '0'); }
    rowY += LAYOUT.rowStep;
    g.AddButton(5104, offsetX + 30, rowY + 4, 0x2716, 0x2716, 0x2716, '');
    g.AddTooltip('Seleziona o resetta Runebook Casa');
    g.AddText(offsetX + 60, rowY, 65, 'Recall Casa');
    if (checked) { g.AddText(sx, rowY, hasCasa ? 53 : 0, hasCasa ? 'X' : '0'); }
    g.AddButton(5105, sx + 20, rowY + 2, 0x04B9, 0x04BA, 0x04B9, '');
    g.AddTooltip('Recall CASA (Sacred Journey)');
    rowY += LAYOUT.rowStep;
    g.AddButton(5106, offsetX + 30, rowY + 4, 0x2716, 0x2716, 0x2716, '');
    g.AddTooltip('Seleziona o resetta Runebook Luna Banca');
    g.AddText(offsetX + 60, rowY, 65, 'Recall Luna Bank');
