g.AddButton(3134, offsetX + 40, offsetY + taliPrompt + 7, 0x2716, 0x2716, 0x2716, '');
g.AddTooltip('Seleziona o resetta Talismano Demon');
g.AddText(offsetX + 100, offsetY + taliPrompt + 5, GetColorStatus("Dress_TalismanDemon"), 'Demon');

taliPrompt += 30;

// TALISMANO - Fey
g.AddButton(3135, offsetX + 60, offsetY + taliPrompt, GetCheckboxStatus("Dress_TalismanFey"), GetCheckboxStatus("Dress_TalismanFey"), GetCheckboxStatus("Dress_TalismanFey"), '');
g.AddButton(3136, offsetX + 40, offsetY + taliPrompt + 7, 0x2716, 0x2716, 0x2716, '');
