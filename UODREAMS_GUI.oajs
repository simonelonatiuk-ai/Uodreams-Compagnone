function WalkToRailWithCombat(x, y) {
    while (!Player.Dead() && Orion.GetDistance(x, y) > 2) {
        if (Orion.GetGlobal('StopAllScripts') === 'true') return;

        var target = FindNearestEnemy();
        if (target) {
            // Se vede un nemico nel range (12 tile), si ferma e lo uccide
            AttackNearestEnemy(); 
        } else {
            // Se la strada è libera, cammina verso il punto per 400ms poi ricontrolla
            Orion.WalkTo(x, y, Player.Z(), 1, 255, 1, 1, 400); 
        }
        Orion.Wait(50);
    }
}


function EventoVoid3() {
    var railCoordinates = [
[6790, 2180], [6808, 2201], [6823, 2187], [6819, 2172], [6842, 2171],
[6792, 2214], [6777, 2214], [6765, 2210], [6748, 2229], [6819, 2225],
[6831, 2225], [6836, 2205], [6808, 2197], [6789, 2189], [6830, 2168],
[6845, 2158], [6827, 2147], [6790, 2179]
];

    var currentIndex = 0;

    while (!Player.Dead()) {
        if (Orion.GetGlobal('StopAllScripts') === 'true') return;

        if (currentIndex >= railCoordinates.length) {
            currentIndex = 0;
        }

        var coord = railCoordinates[currentIndex];
        Orion.WalkTo(coord[0], coord[1], Player.Z(), 1, 255, 1, 10, 10000);

        // 🔍 Check mob fino a 300ms
        var checkDuration = 100;
        var startTime = Orion.Now();

        while (Orion.Now() - startTime < checkDuration) {
            var target = FindNearestEnemy();

            if (target && AttackNearestEnemy()) {
                startTime = Orion.Now(); // resetta il timer se combatte
            } else {
                Orion.Wait(50);
            }
        }

        currentIndex++;
        Orion.Wait(10);
    }
}

