function RaccogliSoldi() {
    var goldID = '0x0EED'; // ID dell'oro
    var distanza = 3;

    while (!Player.Dead()) {
        var items = Orion.FindType(goldID, '-1', 'ground', 'near', distanza);

        for (var i = 0; i < items.length; i++) {
            var item = Orion.FindObject(items[i]);
            if (item && item.Distance() <= distanza) {
                Orion.MoveItem(item.Serial(), item.Amount, 'backpack');
                Orion.Wait(300);
            }
        }

        Orion.Wait(300);
    }
}

function SelectOrResetKhaldunWeapon() {
    var varName = 'kaldun';

    if (Orion.FindObject(varName)) {
        Orion.RemoveObject(varName);
        Shared.RemoveVar(varName + '_name');
        PlayerConfig_RemoveObject(varName);
        Orion.CharPrint(Player.Serial(), 33, 'Arma KALDHUN resettata!');
    } else {
        Orion.CharPrint(Player.Serial(), 55, 'Seleziona arma KALDHUN');
        if (Orion.WaitForAddObject(varName, 15000)) {
            var item = Orion.FindObject(varName);
            if (item) {
                Shared.AddVar(varName + '_name', item.Name());
                PlayerConfig_SaveObject(varName, item.Serial(), item.Name());
                Orion.CharPrint(Player.Serial(), 65, 'Arma KALDHUN salvata: ' + item.Name());
            }
        } else {
            Orion.CharPrint(Player.Serial(), 33, 'Tempo scaduto: nessuna arma selezionata.');
        }
    }

    GUI();
}

function GoldRunnerChase95() {
    var GOLD_ID = '0x0EED';   // oro
    var BAG_ID  = '0x0E76';   // Bag of Sending
    var RAGGIO_PICKUP = 2;    // distanza per raccogliere
    var RAGGIO_SCAN   = 12;   // distanza di ricerca oro a terra
    var lastGoldSerial = null;

    Orion.Print("▶️ GoldRunner 95% + chase avviato (pickup 600 ms, movimento WalkTo)");

    // Trova la Bag nello zaino (se manca, raccoglie solo)
    var bagList = Orion.FindType(BAG_ID, '-1', 'backpack');
    var bagSerial = bagList.length ? bagList[0] : null;
    if (!bagSerial)
        Orion.CharPrint(Player.Serial(), 33, "⚠️ Bag of Sending non trovata!");

    while (!Player.Dead()) {
        var maxW = Player.MaxWeight();
        var curW = Player.Weight();

        // === 1) Invio a banca se peso >= 95% ===
        if (bagSerial && curW >= Math.floor(maxW * 0.95)) {
            Orion.UseObject(bagSerial);
            if (Orion.WaitForTarget(3000)) {
                var goldInBackpack = Orion.FindType(GOLD_ID, '-1', 'backpack');
                if (goldInBackpack.length) {
                    Orion.TargetObject(goldInBackpack[0]);
                } else if (lastGoldSerial) {
                    Orion.TargetObject(lastGoldSerial); // oro “in mano”
                } else {
                    var vicino = Orion.FindType(GOLD_ID, '-1', 'ground', 'near', 1);
                    if (vicino.length) Orion.TargetObject(vicino[0]);
                }
                Orion.CharPrint(Player.Serial(), 65, "🏦 Oro inviato in banca (95%).");
            } else {
                Orion.CharPrint(Player.Serial(), 33, "⚠️ Nessun target dalla Bag of Sending.");
            }
            Orion.Wait(400);
        }

        // === 2) Cerca oro a terra e muoviti verso la pila più vicina ===
        var piles = Orion.FindType(GOLD_ID, '-1', 'ground', 'near', RAGGIO_SCAN);
        if (!piles.length) {
            Orion.Wait(200);
            continue;
        }

        var nearest = null;
        var dist = 999;
        for (var i = 0; i < piles.length; i++) {
            var it = Orion.FindObject(piles[i]);
            if (!it) continue;
            if (it.Distance() < dist) {
                dist = it.Distance();
                nearest = it;
            }
        }
        if (!nearest) {
            Orion.Wait(150);
            continue;
        }

        // Se troppo lontano, cammina verso di esso
        if (nearest.Distance() > RAGGIO_PICKUP) {
            Orion.WalkTo(nearest.X(), nearest.Y(), nearest.Z(), 1, 255, 1, 2, 5000);
            Orion.Wait(400);
        } else {
            // Raccogli
            lastGoldSerial = nearest.Serial();
            Orion.MoveItem(nearest.Serial(), nearest.Amount, 'backpack');
            Orion.Wait(600); // drag/drop fisso
        }

        Orion.Wait(150);
    }

    Orion.CharPrint(Player.Serial(), 55, "⛔ GoldRunner terminato.");
}

function SbloccaSeFermo() {
    var lastX = Player.X();
    var lastY = Player.Y();
    var lastZ = Player.Z();
    var stayCounter = 0;

    while (!Player.Dead()) {
        if (Orion.GetGlobal('StopAllScripts') === 'true') return;

        if (Player.X() === lastX && Player.Y() === lastY && Player.Z() === lastZ) {
            stayCounter++;
        } else {
            lastX = Player.X();
            lastY = Player.Y();
            lastZ = Player.Z();
            stayCounter = 0;
        }

        if (stayCounter >= 55) { // 10 secondi (50 × 200ms)
            stayCounter = 0;
            Orion.CharPrint(Player.Serial(), 33, "*SBORRATO*");

            var path = [5, 5, 5, 6, 6, 6, 2, 2, 2, 7, 7, 7];

            for (var i = 0; i < path.length; i++) {
                Orion.Step(path[i], true);
                if (Orion.ObjAtLayer('Mount') !== null) {
                    Orion.Wait(115);
                } else {
                    Orion.Wait(215);
                }
            }
        }

        Orion.Wait(200);
    }
}

