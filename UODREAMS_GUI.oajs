function doomBoneCutter() {
    var knifeObj = Orion.FindObject('bone_knife');
    
    if (!knifeObj) {
        Orion.CharPrint(Player.Serial(), 33, "⚠️ Nessun coltello selezionato!");
        return;
    }
    
    var knifeSerial = knifeObj.Serial();
    var boneTypes = '0x0ECA|0x0ECB|0x0ECC|0x0ECD|0x0ECE|0x0ECF|0x0ED0|0x0ED1|0x0ED2';

    while (!Player.Dead()) {
        // Interruzione di sicurezza se si spegne tutto dalla GUI
        if (Orion.GetGlobal('StopAllScripts') === 'true') return;

        // Cerca tutte le ossa a terra entro 2 tile (portata d'attacco)
        var bones = Orion.FindTypeEx(boneTypes, 'any', 'ground', 'item|near', 2);

        if (bones.length > 0) {
            for (var i = 0; i < bones.length; i++) {
                var bone = bones[i];
                
                // Verifica che l'osso esista ancora prima di tentare il taglio
                if (bone && Orion.ObjectExists(bone.Serial())) {
                    
                    // 1. Pulisce eventuali mirini rimasti incastrati dal ciclo precedente
                    if (Orion.HaveTarget()) {
                        Orion.CancelTarget();
                    }
                    Orion.CancelWaitTarget();

                    Orion.WaitTargetObject(bone.Serial()); 
                    Orion.UseObject(knifeSerial); 
                    
                    var timeout = Orion.Now() + 200;
                    while (Orion.ObjectExists(bone.Serial()) && Orion.Now() < timeout) {
                        Orion.Wait(20);
                    }
                }
            }
            
            // 4. Sicurezza a fine taglio: se il mirino è rimasto aperto per un fizzle, lo cancella
            if (Orion.HaveTarget()) {
                Orion.CancelTarget();
            }
            Orion.CancelWaitTarget();
        }

        // Controllo rapido del terreno ogni 100ms
        Orion.Wait(100); 
    }
}

function HonorSelf() {
    Orion.ClearJournal();
    Orion.CancelTarget();
    Orion.InvokeVirtue('Honor');

    if (Orion.WaitForTarget(2000)) {
        Orion.TargetObject(Player.Serial());
        Orion.Wait(400); // Attendi il messaggio nel journal

        if (Orion.InJournal('You embrace your honor')) {
            Orion.CharPrint(Player.Serial(), 65, "HONORATO");
        } else if (Orion.InJournal('You must wait')) {
            Orion.CharPrint(Player.Serial(), 33, "ASPETTA PER HONOR");
        } else if (Orion.InJournal('You no longer embrace your honor')) {
            Orion.CharPrint(Player.Serial(), 33, "HONOR FINITO");
        }
    }
}

function IsLagPlayer() {
    var name = Player.Name();

    if (!name) {
        return false;
    }

    name = name.toLowerCase();

    return name === 'fornace';
}



function CheckCurseAndPoison() {
    var lastRemoveCurse = 0;
    var removeCurseCooldown = 1200;

    function HasCurseDebuff() {
        return (
            Orion.BuffExists('Curse') ||
            Orion.BuffExists('Corpse Skin')
        );
    }

    function ClearTargetHard() {
        Orion.CancelTarget();
        Orion.CancelWaitTarget();
    }

    function CastRemoveCurseSelf() {
            ClearTargetHard();

            if (IsLagPlayer()) {
                //Orion.CharPrint(Player.Serial(), 44, 'REMOVE CURSE LAG MODE');

                Orion.Cast('209');

                if (Orion.WaitForTarget(3000)) {
                    Orion.TargetObject('self');
                }

                Orion.Wait(350);
            } else {
                //Orion.CharPrint(Player.Serial(), 65, 'REMOVE CURSE NORMAL MODE');

                Orion.Cast('209');

                if (Orion.WaitForTarget(1200)) {
                    Orion.TargetObject('self');
                }

                Orion.Wait(150);
            }

            ClearTargetHard();
        }

    while (!Player.Dead()) {
        if (Orion.GetGlobal('StopAllScripts') === 'true') {
            return;
        }

        if (Player.Hits() < Player.MaxHits()) {
            Orion.Wait(50);
            continue;
        }

        if (HasCurseDebuff()) {
            var now = Orion.Now();

            if ((now - lastRemoveCurse) < removeCurseCooldown) {
                Orion.Wait(50);
                continue;
            }

            lastRemoveCurse = now;

            CastRemoveCurseSelf();

            var timeout = Orion.Now() + 1500;

            while (HasCurseDebuff() && Orion.Now() < timeout && !Player.Dead()) {
                Orion.Wait(100);
            }

            ClearTargetHard();

            Orion.Wait(150);
            continue;
        }

        Orion.Wait(100);
    }
}


function CheckAndDispelRevenant() {
    while (!Player.Dead()) {
        var mobs = Orion.FindType('0x0190', '-1', 'ground', 'live|ignoreself', 12, 'red');

        for (var i = 0; i < mobs.length; i++) {
            var mob = Orion.FindObject(mobs[i]);
            if (!mob) {
                continue;
            }
            var mobProps = mob.Properties();
            if (Orion.Contains(mobProps, "A Revenant")) {
                Orion.CharPrint(mob.Serial(), 33, "Dispel Evil in corso!");
                while (Orion.ObjectExists(mob.Serial())) {
                    if (Player.Mana() >= 10) {
                        Orion.Cast('Dispel Evil');
                        Orion.Wait(500);
                    } 
                }
                if (!Orion.ObjectExists(mobs[i])) {
                    Orion.CharPrint(mobs[i], 55, "Revenant rimosso!");
                }
            }
        }
        Orion.Wait(200);
    }
}

function Nipo() {
    while (true) {
        // Coordinate attuali
        var x = Player.X();
        var y = Player.Y();
        var z = Player.Z();
        var dir = Player.Direction();

        // Calcola posizione dietro al player
        if (dir === 0) y += 1; // Nord → dietro è sud
        else if (dir === 1 || dir === 2) { x -= 1; y += 1; } // NE / Est
        else if (dir === 3 || dir === 4) y -= 1; // Sud → dietro è nord
        else if (dir === 5 || dir === 6) { x += 1; y -= 1; } // SW / Ovest
        else if (dir === 7) y += 1;

        var moved1 = Orion.MoveItemType('0x0EEF', 'any', 'backpack', 0, 'ground', x, y, z);
        if (moved1) {
            Orion.Print('✅ Oggetto 0x0EEF droppato dietro di te.');
        } else {
            Orion.Print('⚠️ Nessun 0x0EEF trovato.');
        }

        Orion.Wait(500);
        var moved2 = Orion.MoveItemType('0x11EA', 'any', 'backpack', 0, 'ground', x, y, z);
        if (moved2) {
            Orion.Print('✅ Oggetto 0x11EA droppato dietro di te.');
        } else {
            Orion.Print('⚠️ Nessun 0x11EA trovato.');
        }
        // Attesa prima del prossimo tentativo
        Orion.Wait(1000);
    }
}

function AutoLogoutOnDeath() {
    Orion.Print('Script AutoLogoutOnDeath avviato...');
    while (true) {
        Orion.Wait(1000);
       // Controlla se il personaggio è morto
        if (Player.Dead()) {
            Orion.LogOut();
            break; // Termina lo script
        }
    }
}

function AttackNearestEnemy() {
    var maxWaitCycles = 20;
    var waitCount = 0;

    Orion.IgnoreReset();
    Orion.Ignore('self');

    var friends = Orion.GetFriendList();
    for (var i = 0; i < friends.length; i++) {
        Orion.Ignore(friends[i]);
    }

    while (!Player.Dead() && waitCount < maxWaitCycles) {
        if (Orion.GetGlobal('StopAllScripts') === 'true') {
            return false;
        }

        if (HandleBloodOath()) {
            continue;
        }

        Orion.WarMode(true);

        var target = FindNearestEnemy();

        if (target) {
            var currentSerial = target.Serial();

            if (ignoredMobs[currentSerial] || isIgnoredSummon(target)) {
                ignoredMobs[currentSerial] = true;
                Orion.Ignore(currentSerial);
                waitCount++;
                Orion.Wait(100);
                continue;
            }

            Orion.ShowStatusbar(currentSerial, 1150, 1200);
            Orion.AddHighlightCharacter(currentSerial, 0x081C, true);
            Orion.CharPrint(currentSerial, 20, "*target*");

            var lastX = Player.X();
            var lastY = Player.Y();
            var lastZ = Player.Z();

            var stayCounter = 0;
            var walkAttempts = 0;

            while (!Player.Dead() && Orion.ObjectExists(currentSerial)) {
                if (Orion.GetGlobal('StopAllScripts') === 'true') {
                    Orion.CloseStatusbar(currentSerial);
                    return false;
                }

                if (HandleBloodOath()) {
                    break;
                }

                var newTarget = FindNearestEnemy();

                if (newTarget) {
                    var newSerial = newTarget.Serial();

                    if (ignoredMobs[newSerial] || isIgnoredSummon(newTarget)) {
                        ignoredMobs[newSerial] = true;
                        Orion.Ignore(newSerial);
                    } else if (newSerial !== currentSerial) {
                        Orion.CloseStatusbar(currentSerial);

                        target = newTarget;
                        currentSerial = newSerial;

                        Orion.ShowStatusbar(currentSerial, 1150, 1200);
                        Orion.AddHighlightCharacter(currentSerial, 0x081C, true);
                        Orion.CharPrint(currentSerial, 20, "*target*");

                        lastX = Player.X();
                        lastY = Player.Y();
                        lastZ = Player.Z();

                        stayCounter = 0;
                        walkAttempts = 0;
                    }
                }

                var targetObject = Orion.FindObject(currentSerial);

                if (!targetObject || targetObject.Dead()) {
                    break;
                }

                if (ignoredMobs[currentSerial] || isIgnoredSummon(targetObject)) {
                    ignoredMobs[currentSerial] = true;
                    Orion.Ignore(currentSerial);
                    break;
                }

                if (targetObject.Distance() > 1) {
                    Orion.WalkTo(targetObject.X(), targetObject.Y(), targetObject.Z(), 1, 255, 1, 2, 5000);
                    Orion.Wait(200);
                    walkAttempts++;
                } else {
                    walkAttempts = 0;
                }

                if (walkAttempts >= 5) {
                    ignoredMobs[currentSerial] = true;
                    Orion.Ignore(currentSerial);
                    Orion.CharPrint(Player.Serial(), 33, "*Ignorato: irraggiungibile* " + targetObject.Name());
                    Orion.CloseStatusbar(currentSerial);
                    return false;
                }

                if (targetObject.Distance() <= 11) {
                    Orion.Attack(currentSerial);
                }

                if (Player.X() === lastX && Player.Y() === lastY && Player.Z() === lastZ) {
                    stayCounter++;
                } else {
                    lastX = Player.X();
                    lastY = Player.Y();
                    lastZ = Player.Z();
                    stayCounter = 0;
                }

                if (stayCounter >= 12000) {
                    ignoredMobs[currentSerial] = true;
                    Orion.Ignore(currentSerial);
                    Orion.CharPrint(Player.Serial(), 33, "*Ignorato* " + targetObject.Name());
                    Orion.CloseStatusbar(currentSerial);
                    return false;
                }

                Orion.Wait(10);
            }

            Orion.CloseStatusbar(currentSerial);
            return true;

        } else {
            waitCount++;
            Orion.Wait(10);
        }
    }

    return false;
}


function SeguieMena() {
    while (!Player.Dead()) {
        var target = FindNearestEnemy();

        if (target) {
            var success = AttackNearestEnemy(); // ⚠️ Usa già tutta la logica con controlli, ignora, ecc.
            if (!success) {
                Orion.CharPrint(Player.Serial(), 33, "Target ignorato, cercando altro...");
            }
        } else {
            Orion.Wait(300); // Aspetta un attimo prima di riprovare
        }
    }
}

function Formiche() {
    var railCoordinates = [
[6089, 1349], [6089, 1339], [6093, 1330], [6086, 1320], [6093, 1311],[6091, 1322], [6095, 1334], [6101, 1343], [6111, 1347], [6117, 1342],[6116, 1334], [6112, 1327], [6117, 1324], [6117, 1333], [6119, 1340],[6119, 1353], [6123, 1360], [6118, 1367], [6117, 1375], [6112, 1377],[6106, 1372], [6108, 1365], [6105, 1358], [6100, 1356], [6093, 1362],[6084, 1368], [6077, 1371], [6073, 1367], [6074, 1361], [6075, 1360],[6067, 1356], [6059, 1358], [6046, 1361], [6044, 1373], [6052, 1381],[6047, 1374], [6047, 1364], [6049, 1349], [6051, 1339], [6056, 1332],[6065, 1331], [6066, 1322], [6071, 1323], [6062, 1335], [6054, 1342],[6059, 1354], [6071, 1347], [6080, 1353], [6089, 1348]
    ];

    var currentIndex = 0;

    while (!Player.Dead()) {
        if (Orion.GetGlobal('StopAllScripts') === 'true') return;

        if (currentIndex >= railCoordinates.length) {
            currentIndex = 0;
        }

        var coord = railCoordinates[currentIndex];
        // 🔍 Check pozze di acido entro 1 tile dalla prossima posizione
        var acidPuddles = Orion.FindType('0x122A', '-1', 'ground', null, 2);
        var avoidTile = acidPuddles.some(function(p) {
            var obj = Orion.FindObject(p);
            return obj && Math.abs(obj.X() - coord[0]) <= 1 && Math.abs(obj.Y() - coord[1]) <= 1;
        });

        if (avoidTile) {
            Orion.CharPrint(Player.Serial(), 33, "🧪 Acido rilevato, salto tile!");
            currentIndex++;
            Orion.Wait(10);
            continue;
        }
        Orion.WalkTo(coord[0], coord[1], Player.Z(), 1, 255, 1, 10, 10000);

        var checkDuration = 100;
        var startTime = Orion.Now();

        while (Orion.Now() - startTime < checkDuration) {
            var target = FindNearestEnemy();
            if (target && AttackNearestEnemy()) {
                startTime = Orion.Now();
            } else {
                Orion.Wait(50);
            }
        }

        currentIndex++;
        Orion.Wait(10);
    }
}

