function UseBagOfSending() {
    var bag = Orion.FindType('0x0E76', '-1', 'backpack');

    if (!bag.length) {
        Orion.CharPrint(Player.Serial(), 33, "Bag of Sending non trovata nello zaino!");
        return;
    }

    Orion.PauseScript('RaccogliSoldi');
    Orion.CharPrint(Player.Serial(), 55, "Golddigger messo in pausa");

    var gold = Orion.FindType('0x0EED', '-1', 'backpack');
    if (!gold.length) {
        Orion.CharPrint(Player.Serial(), 33, "Nessun oro trovato nello zaino!");
        Orion.ResumeScript('RaccogliSoldi');
        return;
    }

    Orion.UseObject(bag[0]);
    if (Orion.WaitForTarget(3000)) {
        Orion.TargetObject(gold[0]);
        Orion.CharPrint(Player.Serial(), 65, "Oro spedito in banca");
    } else {
        Orion.CharPrint(Player.Serial(), 33, "Nessun target ricevuto da Bag of Sending");
    }

    Orion.Wait(800); // attesa finale
    Orion.ResumeScript('RaccogliSoldi');
    Orion.CharPrint(Player.Serial(), 65, "▶️ Golddigger riattivato");
}


function AutoHonorMob() {
    var currentHonored = null;   // serial del mob attualmente honorato
    var failedHonor = {};        // serial -> true (troppo danneggiato / self-honor)
    var lastHonorTime = 0;       // per il cooldown tra tentativi
    var COOLDOWN_MS = 400;      // intervallo minimo tra tentativi

    function nearestEnemy() {
        var list = Orion.FindType(
            '-1', '-1', 'ground', 'live|ignoreself|ignorefriends',
            12, 'gray|criminal|red|enemy|orange'
        );
        if (!list || !list.length) return null;

        // Converte i seriali in oggetti
        var objs = [];
        for (var i = 0; i < list.length; i++) {
            var o = Orion.FindObject(list[i]);
            if (o) objs.push(o);
        }
        if (!objs.length) return null;

        // Ordina per distanza
        objs.sort(function(a, b){ return a.Distance() - b.Distance(); });
        return objs[0];
    }

    function hardClearTargets() {
    // ✅ non rompere il target manuale dello zaino
    if (Orion.HaveTarget && Orion.HaveTarget()) return;

    try { Orion.CancelTarget(); } catch(e){}
    try { Orion.CancelWaitTarget && Orion.CancelWaitTarget(); } catch(e){}
    try { Orion.ClearTargetQueue && Orion.ClearTargetQueue(); } catch(e){}
    try { Orion.ClearTargets && Orion.ClearTargets(); } catch(e){}
}


    function tryHonor(target) {
        if (!target) return false;
        if (failedHonor[target.Serial()]) return false;

        // pulizia minimi prima del nuovo tentativo
        Orion.ClearJournal();
        hardClearTargets();
        Orion.Wait(50);

        // prepara il target, poi invoca la Virtue
        Orion.WaitTargetObject(target.Serial());
        Orion.InvokeVirtue("Honor");
        Orion.Wait(250);

        // esiti comuni
        if (Orion.InJournal("You started Honorable Combat")) {
            Orion.CharPrint(target.Serial(), 65, "HONORATO → " + target.Name());
            currentHonored = target.Serial();
            lastHonorTime = Orion.Now();
            return true;
        }

        if (Orion.InJournal("You cannot honor this monster because it is too damaged")) {
            Orion.CharPrint(target.Serial(), 44, "Gia danneggiato → " + target.Name());
            failedHonor[target.Serial()] = true;
            lastHonorTime = Orion.Now();
            return false;
        }

        if (Orion.InJournal("You embrace your honor")) {
            Orion.CharPrint(Player.Serial(), 33, "Hai honorato te stesso per errore!");
            failedHonor[target.Serial()] = true;
            lastHonorTime = Orion.Now();
            return false;
        }

        // Alcuni shard mostrano messaggi di attesa/cooldown
        if (Orion.InJournal("You must wait") || Orion.InJournal("not yet recovered")) {
            lastHonorTime = Orion.Now();
            return false;
        }

        return false;
    }

    while (!Player.Dead()) {
        if (Orion.GetGlobal('StopAllScripts') === 'true') return;

        // Se avevamo un target honorato, verifica se è ancora vivo
        if (currentHonored) {
            var obj = Orion.FindObject(currentHonored);

            // Se non esiste più o non è vivo → resetta e PULISCI tutto
            if (!obj || obj.Hits && obj.Hits() <= 0) {
                currentHonored = null;
                hardClearTargets();
                Orion.ClearJournal();
                // piccolo respiro prima di cercare il prossimo
                Orion.Wait(300);
            } else {
                // è ancora vivo: non cercare altri
                Orion.Wait(200);
                continue;
            }
        }

        // Cooldown minimo tra tentativi
        if (Orion.Now() - lastHonorTime < COOLDOWN_MS) {
            Orion.Wait(100);
            continue;
        }

        // Cerca il prossimo nemico
        var enemy = nearestEnemy();
        if (enemy && !currentHonored) {
            tryHonor(enemy);
        }

        Orion.Wait(150);
    }
}




function CercaOggettoTerra() {
    Orion.Print('0x60', '▶ Cercatore oggetti AVVIATO');
    Shared.AddVar('cerca_attivo', true);

    while (!Player.Dead() && Shared.GetVar('cerca_attivo')) {
