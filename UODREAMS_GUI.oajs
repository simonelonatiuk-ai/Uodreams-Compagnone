// --- VARIABILE GLOBALE (da tenere in alto nel file) ---
var lastEOOTarget = '';

// --- VARIABILE GLOBALE (da tenere in alto nel file) ---
var lastEOOTarget = '';

function SoloFollowAndAttack() {
    var honoredTarget = null;
    var GIVE_UP_DISTANCE = 10;

    ignoredMobs = {};

    while (!Player.Dead()) {
        if (Orion.GetGlobal('StopAllScripts') === 'true')
            return;

        if (HandleBloodOath()) {
            continue;
        }

        Orion.WarMode(true);

        var enemy = GetClosestEnemySolo();

        if (enemy) {
            var currentSerial = enemy.Serial();

            if (!honoredTarget || honoredTarget.Serial() !== currentSerial) {
                if (TryHonorEnemy(enemy))
                    honoredTarget = enemy;
                else
                    honoredTarget = null;
            }

            while (!Player.Dead() && Orion.ObjectExists(currentSerial)) {
                enemy = Orion.FindObject(currentSerial);

                if (!enemy || enemy.Dead())
                    break;

                if (HandleBloodOath()) {
                    break;
                }

                var noto = enemy.Notoriety();

                if ((noto === 3 || noto === 6) && lastEOOTarget !== currentSerial) {
                    if (Player.Mana() >= 14) {
                        if (Orion.BuffExists('Enemy of One')) {
                            Orion.Cast('Enemy of One');

                            var offTimeout = 0;
                            while (Orion.BuffExists('Enemy of One') && offTimeout < 10) {
                                Orion.Wait(250);
                                offTimeout++;
                            }

                            Orion.Wait(150);
                        }

                        Orion.Cast('Enemy of One');

                        var onTimeout = 0;
                        while (!Orion.BuffExists('Enemy of One') && onTimeout < 10) {
                            Orion.Wait(200);
                            onTimeout++;
                        }

                        if (Orion.BuffExists('Enemy of One')) {
                            lastEOOTarget = currentSerial;
                        }
                    }
                }

                if (ignoredMobs[currentSerial] || isIgnoredSummon(enemy)) {
                    Orion.Ignore(currentSerial);
                    ignoredMobs[currentSerial] = true;
                    break;
                }

                if (enemy.Distance() > GIVE_UP_DISTANCE) {
                    break;
                }

                if (enemy.Distance() > 1) {
                    Orion.WalkTo(enemy.X(), enemy.Y(), enemy.Z(), 1, 255, 1, 2, 5000);
                }

                if (enemy.Distance() <= 12) {
                    Orion.Attack(currentSerial);
                }

                Orion.Wait(100);
            }

            honoredTarget = null;
            Orion.CancelTarget();

        } else {
            lastEOOTarget = '';
            Orion.Wait(100);
        }
    }
}

function SoloFollowAndAttackSS() {
    var honoredTarget = null;
    var GIVE_UP_DISTANCE = 10;

    ignoredMobs = {};

    while (!Player.Dead()) {
        if (Orion.GetGlobal('StopAllScripts') === 'true') {
            return;
        }

        if (HandleBloodOath()) {
            continue;
        }

        Orion.WarMode(true);

        var enemy = GetClosestEnemySolo();

        if (enemy) {
            var currentSerial = enemy.Serial();

            // HARD GATE iniziale: se è summon o mob ignorato, non lo considera proprio
            if (ignoredMobs[currentSerial] || isIgnoredSummon(enemy)) {
                Orion.Ignore(currentSerial);
                ignoredMobs[currentSerial] = true;
                honoredTarget = null;
                Orion.Wait(100);
                continue;
            }

            if (!honoredTarget || honoredTarget.Serial() !== currentSerial) {
                if (TryHonorEnemy(enemy)) {
                    honoredTarget = enemy;
                } else {
                    honoredTarget = null;
                }
            }

            while (!Player.Dead() && Orion.ObjectExists(currentSerial)) {
                if (HandleBloodOath()) {
                    break;
                }

                enemy = Orion.FindObject(currentSerial);

                if (!enemy || enemy.Dead()) {
                    break;
                }

                // HARD GATE durante il fight
                if (ignoredMobs[currentSerial] || isIgnoredSummon(enemy)) {
                    Orion.Ignore(currentSerial);
                    ignoredMobs[currentSerial] = true;
                    break;
                }

                if (enemy.Distance() > GIVE_UP_DISTANCE) {
                    break;
                }

                if (enemy.Distance() > 1) {
                    Orion.WalkTo(enemy.X(), enemy.Y(), enemy.Z(), 1, 255, 1, 2, 5000);
                    Orion.Wait(100);
                }

                if (enemy.Distance() <= 12) {
                    Orion.Attack(currentSerial);
                }

                Orion.Wait(100);
            }

            honoredTarget = null;
            Orion.CancelTarget();

        } else {
            Orion.Wait(300);
        }
    }
}

var failedHonorTargets = {};

function TryHonorEnemy2(enemy) {
    if (!enemy || enemy.Serial() === Player.Serial()) return false;

    if (failedHonorTargets[enemy.Serial()]) return false;

    Orion.ClearJournal();
    Orion.CancelTarget();
    Orion.InvokeVirtue('Honor');

    if (!Orion.WaitForTarget(2000)) {
        Orion.CharPrint(Player.Serial(), 33, "Target Honor non attivo");
        return false;
    }

    var refreshed = Orion.FindObject(enemy.Serial());
    if (!refreshed || refreshed.Hits() <= 0 || !refreshed.Exists()) {
        Orion.CancelTarget();
        return false;
    }

    Orion.TargetObject(enemy.Serial());
    Orion.Wait(600);

    if (Orion.InJournal('You started Honorable Combat')) {
        Orion.CharPrint(Player.Serial(), 65, "HONORATO : " + enemy.Name());
        return true;
    }

    if (Orion.InJournal('You cannot honor this monster because is too damaged')) {
        Orion.CharPrint(Player.Serial(), 44, "Honor fallito (già danneggiato): " + enemy.Name());
        failedHonorTargets[enemy.Serial()] = true;
        return false;
    }

    if (Orion.InJournal('You embrace your honor')) {
        Orion.CharPrint(Player.Serial(), 33, "Hai onorato te stesso per errore!");
        failedHonorTargets[enemy.Serial()] = true;
        return false;
    }

    Orion.CharPrint(Player.Serial(), 44, "HONOR FAIL (già danneggiato) : " + enemy.Name());
    failedHonorTargets[enemy.Serial()] = true;
    return false;
}

function GetClosestEnemySolo() {
    Orion.IgnoreReset();
    Orion.Ignore('self');

    var friends = Orion.GetFriendList();
    for (var i = 0; i < friends.length; i++) {
        Orion.Ignore(friends[i]);
    }

    // FindTypeEx qui ritorna OGGETTI, non seriali
    var enemies = Orion.FindTypeEx(
        'any',
        'any',
        'ground',
        'ignoreself|ignorefriends|live|inlos|mobile',
        10,
        'gray|criminal|red|orange|enemy'
    );

    // ✅ filtra EV/RC e roba ignorata
    var filtered = [];
    for (var j = 0; j < enemies.length; j++) {
        var o = enemies[j]; // <-- QUESTO è l’oggetto
        if (!o) continue;

        // se in mappa ignorati
        if (ignoredMobs[o.Serial()]) continue;

if (isIgnoredSummon(o)) {
    Orion.Ignore(o.Serial());
    ignoredMobs[o.Serial()] = true;   // ✅ IMPORTANTISSIMO
    continue;
}


        filtered.push(o);
    }

    if (filtered.length > 0) {
        filtered.sort(function (a, b) {
            return a.Distance() - b.Distance();
        });
        return filtered[0];
    }

    return null;
}


function ResetIgnoredMobs() {
    ignoredMobs = {};
    Orion.IgnoreReset();
    Orion.CharPrint(Player.Serial(), 65, "Lista ignorati azzerata");
}

var failedHonorTargets = {};

function TryHonorEnemy(enemy) {
    if (!enemy || enemy.Serial() === Player.Serial()) return false;
    if (failedHonorTargets[enemy.Serial()]) return false;

    function tryOnce() {
        Orion.Ignore('self');
        Orion.RemoveObject("target");
        Orion.AddObject("target", enemy.Serial());
        Orion.Wait(100);

        Orion.ClearJournal();
        Orion.CancelTarget();

        Orion.WaitTargetObject(enemy.Serial());
        Orion.InvokeVirtue("Honor");
        Orion.Wait(250);
    }

    tryOnce();

    // retry se “Target cannot be seen”
    if (Orion.InJournal("Target cannot be seen")) {
        Orion.Wait(300);
        tryOnce();
    }

    if (Orion.InJournal("You started Honorable Combat")) {
        Orion.CharPrint(Player.Serial(), 65, "HONORATO: " + enemy.Name());
        return true;
    }

    if (Orion.InJournal("You cannot honor this monster because it is too damaged")) {
        Orion.CharPrint(Player.Serial(), 44, "GIA DANNEGGIATO → " + enemy.Name());
        failedHonorTargets[enemy.Serial()] = true;
        Orion.CancelTarget();
        return false;
    }

    if (Orion.InJournal("You embrace your honor")) {
        Orion.CharPrint(Player.Serial(), 33, "HONORATO TE STESSO PER ERRORE!");
        failedHonorTargets[enemy.Serial()] = true;
        return false;
    }

    return false;
}

function MountPetManager() {
    Orion.CharPrint(Player.Serial(), 55, "Seleziona un pet da salvare");

    if (Orion.WaitForAddObject('mount_temp', 25000)) {
        var pet = Orion.FindObject('mount_temp');
        if (pet) {
            // Usa FindList come storage "persistente"
            var graphic = pet.Graphic();
            var color = pet.Color();
            var name = pet.Name() || 'Pet';

            Orion.AddFindList('savedMounts', graphic, color, name);
            Orion.CharPrint(Player.Serial(), 65, "Pet aggiunto alla lista : " + name);
        }
    }

    GUI();
}

function autoMount() {
    while (!Player.Dead()) {
        var isMounted = Orion.ObjAtLayer('myMount') !== null;
        if (!isMounted && Orion.BuffExists('dismount')) {
            Orion.Say('All follow Me');
            Orion.Wait(1500);
            continue;
        }

        var pets = Orion.FindList('savedMounts', 'ground', null, 18);
        for (var i = 0; i < pets.length; i++) {
            var pet = Orion.FindObject(pets[i]);
            if (!pet || pet.Hits() <= 0) continue;

            Orion.GetStatus(pet.Serial());
            Orion.Wait(100);

            if (pet.Poisoned() && Player.Mana() >= 10) {
                Orion.Cast('Cleanse by Fire');
                if (Orion.WaitForTarget(1500)) {
                    Orion.TargetObject(pet.Serial());
                    Orion.Wait(300);
                }
            }
            
            if (pet.YellowHits() && Player.Mana() >= 20) {
                Orion.Cast('Remove Curse');
                if (Orion.WaitForTarget(1500)) {
                    Orion.TargetObject(pet.Serial());
                    Orion.Wait(400);
                }
            }

            Orion.WarMode(false);
            Orion.UseObject(pet.Serial());
            Orion.Wait(50);

            if (Orion.ObjAtLayer('myMount') !== null) break;
        }

        Orion.Wait(50);
    }
}

function SetKnifeForBoneCutter() {
    var knife = Orion.FindObject('bone_knife');
    var savedKnifeName = Shared.GetVar('bone_knife_name');

    if (knife || savedKnifeName) {
        Orion.RemoveObject('bone_knife');
        Shared.RemoveVar('bone_knife_name');
        PlayerConfig_RemoveObject('bone_knife');
        Orion.CharPrint(Player.Serial(), 33, "Coltello BoneCutter resettato!");
    } else {
        Orion.CharPrint(Player.Serial(), 55, "Seleziona il coltello per il BoneCutter!");
        if (Orion.WaitForAddObject('bone_knife', 25000)) {
            var selected = Orion.FindObject('bone_knife');
            if (selected) {
                Orion.GetStatus(selected.Serial());
                Shared.AddVar('bone_knife_name', selected.Name());
                PlayerConfig_SaveObject('bone_knife', selected.Serial(), selected.Name());
            }
        }
    }

    GUI();
}

function GetKnifeName() {
    var knife = Orion.FindObject('bone_knife');

    if (knife) {
        Orion.GetStatus(knife.Serial());
        var name = knife.Name();
        if (name && name.length > 0) {
            Shared.AddVar('bone_knife_name', name);
        }
        return name && name.length > 0 ? name : '[caricamento...]';
    }

    var savedName = Shared.GetVar('bone_knife_name');
    return savedName ? savedName : 'non selezionato';
}

function GetCercaOggettoName() {
    var obj = Orion.FindObject('oggetto_terra');
    if (obj) {
        Orion.GetStatus(obj.Serial());
        var name = obj.Name();
        if (name && name.length > 0) {
            Shared.AddVar('oggetto_terra_name', name);
        }
        return name && name.length > 0 ? name : '[caricamento...]';
    }
    // Se non c'è un oggetto targettato, mostra il valore manuale (se presente)
    var manualID = Shared.GetVar('graphic_id_manuale');
    if (manualID) {
        return manualID;
    }

    var saved = Shared.GetVar('oggetto_terra_name');
    return saved ? saved : 'non selezionato';
}

