function AggroMobs() {
    var range = 14; // Raggio in cui cercare i mob
    var highlightColor = '0x0015'; // Colore di evidenziazione per i mob
    var ignoredMobTypes = ['an energy vortex', 'a rising colossus']; // Escludere alcuni mob
    var aggroedMobs = {}; // Mappa per tracciare i mob già aggrati

    while (true) {
        // Cerca tutti i mob entro il range specificato
        var mobs = Orion.FindTypeEx('any', 'any', 'ground', 'mobile|live|ignorefriends|inlos', range, 'gray|red|orange');

        for (var i = 0; i < mobs.length; i++) {
            var mob = mobs[i];
            var mobSerial = mob.Serial();
           // Escludi mob che appartengono alla lista ignorata o che sono già aggrati
            if (ignoredMobTypes.indexOf(mob.Name()) !== -1 || aggroedMobs[mobSerial]) {
                continue;
            }
            // Evidenzia il mob
            Orion.AddHighlightCharacter(mobSerial, highlightColor, true);
            // Aggra il mob
            Orion.Attack(mobSerial);
            // Aggiungi il mob alla lista dei già aggrati
            aggroedMobs[mobSerial] = true;
        }
       // Pulizia della lista per rimuovere i mob non più validi
        for (var serial in aggroedMobs) {
            if (!Orion.ObjectExists(serial)) {
                delete aggroedMobs[serial];
            }
        }
        // Ritardo tra le iterazioni per evitare uso eccessivo di risorse
        Orion.Wait(900);
    }
}


function HonorTarget(target) {
    if (!target) return false; // Controlla che il bersaglio sia valido

    Orion.InvokeVirtue('Honor');
    if (Orion.WaitForTarget(2000)) {
        Orion.TargetObject(target.Serial());
        Orion.Wait(200); // Pausa per garantire l'esecuzione
        return true; // Honor riuscito
    }
    return false; // Honor fallito
}

