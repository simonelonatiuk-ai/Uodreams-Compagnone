    AddSmallSetButton(g, 7302, offsetX + 145, offsetY + 250, '33', 'Reset Durability');
    g.AddText(offsetX + 165, offsetY + 247, 33, 'Reset Dura');

    g.AddButton(7300, offsetX + 250, offsetY + 12, 0xA94, 0xA94, 0xA95, '');
