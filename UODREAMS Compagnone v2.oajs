function DoomEquipRoom1() {
    EquipDoomTalismanSimple('talisman_undead', 'Talisman Undead');
    Orion.Wait(150);
    EquipDoomWeaponSimple('doom_darknight_creeper', 'Darknight Creeper');
    EnsureDoomWeaponSimple('doom_darknight_creeper', 'Darknight Creeper');
}

