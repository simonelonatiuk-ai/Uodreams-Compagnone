var telegram_token = "8778713089:AAH9mjw-nd48Y6eqvWpIIcXvb0iybpIXmC0";

// Inserisci qui l'ID del GRUPPO (inizia quasi sempre con un meno '-')
var telegram_chat_id = "-5256370263"; 

function InviaTelegram(testo) {
    var url = "https://api.telegram.org/bot" + telegram_token + "/sendMessage?chat_id=" + telegram_chat_id + "&text=" + encodeURIComponent(testo);
    try { Orion.HttpGet(url); } catch (e) {}
}

function NotificaMorteDoom() {
    var pgName = Player.Name ? Player.Name() : 'Sconosciuto';
    var msg = "☠️ MORTE A DOOM!\n" +
              "👤 Personaggio: " + pgName + "\n" +
              "💀 Il PG " + pgName + " è morto!";
    Orion.Print(33, '>> Invio notifica morte Telegram per: ' + pgName);
    InviaTelegram(msg);
}

function MonitorDoomDrops() {
    Shared.AddVar('doom_watcher_active', true);
    Orion.Print(65, '--> MONITOR DOOM AVVIATO');
    
    var artifactNames = [
        "Ægis", "Arcane Shield", "Armor of Fortune", "Axe of the Heavens", 
        "The Berserker's Maul", "Blade of Insanity", "Bone Crusher", 
        "Bracelet of Health", "Breath of the Dead", "Two Handed Axe", 
        "The Deceiver", "Divine Countenance", "The Dragon Slayer", 
        "The Dryad Bow", "Frostbringer", "Gauntlets of Nobility", 
        "Glenda", "Hat of the Magi", "Helm of Insight", 
        "Holy Knight's Breastplate", "Hunter's Headdress", "Composite Bow", 
        "Bow of Infinite Swarms", "Jackal's Collar", "Legacy of the Dread Lord", 
        "Leggings of Bane", "Midnight Bracers", "Ornament of the Magician", 
        "Ornate Crown of the Harrower", "Ring of the Elements", "Ring of the Vile", 
        "Bandana", "The Scholar’s Halo", "Serpent's Fang", "Shadow Dancer Leggings", 
        "Spirit of the Totem", "Staff of the Magi", "The Taskmaster", 
        "Tunic of Fire", "Voice of the Fallen King"
    ];

    var visti = {}; 
    var initialItems = Orion.FindType('any', 'any', 'backpack');
    for (var j = 0; j < initialItems.length; j++) {
        visti[initialItems[j]] = true;
    }

    while (Shared.GetVar('doom_watcher_active')) {
        var items = Orion.FindType('any', 'any', 'backpack');
        
        for (var i = 0; i < items.length; i++) {
            var serial = items[i];
            
            if (!visti[serial]) {
                var obj = Orion.FindObject(serial);
                if (obj && obj.Exists()) {
                    var name = obj.Name();
                    
                    if (!name || name.length < 2) {
                        Orion.Click(serial);
                        Orion.Wait(500);
                        name = obj.Name();
                    }

                    var isArtifact = false;
                    for (var a = 0; a < artifactNames.length; a++) {
                        if (name.toLowerCase().indexOf(artifactNames[a].toLowerCase()) !== -1) {
                            isArtifact = true;
                            break;
                        }
                    }

                    if (isArtifact) {
                        // Incrementa Counter GUI
                        var dropTotal = Number(Shared.GetVar('doom_watcher_drop_total')) || 0;
                        Shared.AddVar('doom_watcher_drop_total', dropTotal + 1);
                        if (typeof DoomWatcherGUI === 'function') DoomWatcherGUI();

                        // Messaggio personalizzato con il nome del PG che ha droppato
                        var msg = "🎉 NUOVO DROP A DOOM!\n" +
                                  "👤 Personaggio: " + Player.Name() + "\n" +
                                  "🎁 Oggetto: " + name;
                                  
                        InviaTelegram(msg);
                        
                        Orion.Print(65, ">> Drop : " + Player.Name());
                    }
                    visti[serial] = true;
                }
            }
        }
        Orion.Wait(1000); 
    }
}
