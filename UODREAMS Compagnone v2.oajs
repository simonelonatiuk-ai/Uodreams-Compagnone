function AddFarmCheckRow(g, id, xBtn, xText, y, scriptName, label, tooltip) {
    var active = Orion.ScriptRunning(scriptName);

    g.AddButton(id, xBtn, y, active ? 0x2602 : 0x2603, active ? 0x2602 : 0x2603, active ? 0x2602 : 0x2603, '');
    g.AddTooltip(tooltip || label);
    g.AddText(xText, y + 5, active ? HUE_ACTIVE_TEXT : HUE_OFF_TEXT, label);
}


