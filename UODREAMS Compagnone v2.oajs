    EquipDoomTalismanSimple('talisman_demon', 'Talisman Demon');
    Orion.Wait(150);
    EquipDoomWeaponSimple('doom_impaler', 'Impaler');
    EnsureDoomWeaponSimple('doom_impaler', 'Impaler');
}

function DoomEquipRoom4() {
