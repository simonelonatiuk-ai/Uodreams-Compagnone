    EquipDoomTalismanSimple('talisman_undead', 'Talisman Undead');
    Orion.Wait(150);
    EquipDoomWeaponSimple('doom_fleshrenderer', 'Fleshrenderer');
    EnsureDoomWeaponSimple('doom_fleshrenderer', 'Fleshrenderer');
}

