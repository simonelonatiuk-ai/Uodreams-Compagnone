function Message() {
    var x = Player.X(), y = Player.Y();

    if (x === 28 && y === 212) Orion.Say('Ord');
    else if (x === 43 && y === 212) Orion.Say('An-Ord');
    else Orion.Say('*bank* *recsu* *recdu* *guards* *cross*');
}

function CheckObjectColorNumber() {
    Orion.Print(55, 'Seleziona oggetto o mob per leggere il colore...');

    Orion.AddObject('check_color_target');

    while (Orion.HaveTarget()) Orion.Wait(50);

    var obj = Orion.FindObject('check_color_target');

    if (!obj) {
        Orion.Print(33, 'Nessun oggetto selezionato.');
        return;
    }

    var colorHex = obj.Color();
    var colorDec = parseInt(colorHex, 16);

    Orion.Print(66, 'Name: ' + obj.Name());
    Orion.Print(66, 'Serial: ' + obj.Serial());
    Orion.Print(66, 'Graphic: ' + obj.Graphic());
    Orion.Print(66, 'Color Hex: ' + colorHex);
    Orion.Print(66, 'Color Dec: ' + colorDec);
}

function ShowKarmaFama() {
    Orion.ClearJournal();
    Orion.Say('[premium');

    if (Orion.WaitForGump(1000)) {
        var gump0 = Orion.GetGump('last');

        if ((gump0 !== null) && (!gump0.Replayed()) && (gump0.ID() === '0x5CB83289')) {
            gump0.Select(Orion.CreateGumpHook(3));
            Orion.Wait(200);
        }
    }

    var journalLine = Orion.InJournal('Fame');

    if (journalLine) {
        var text = '';

        if (journalLine.Text) text = journalLine.Text();
        else if (journalLine.Message) text = journalLine.Message();
        else text = '' + journalLine;

        Orion.Print(65, 'Fame/Karma: ' + text);

        var match = text.match(/Fame\s*=\s*(-?\d+)\s+Karma\s*=\s*(-?\d+)/i);

        if (match) {
            var fame = Number(match[1]);
            var karma = Number(match[2]);

            Orion.CharPrint(Player.Serial(), 1153, '*FAMA* : ' + fame);
            Orion.Wait(150);

            if (karma < 0) {
                Orion.CharPrint(Player.Serial(), 33, '*KARMA* : ' + karma);
            } else {
                Orion.CharPrint(Player.Serial(), 88, '*KARMA* : ' + karma);
            }
        } else {
            Orion.CharPrint(Player.Serial(), 33, '*Formato Fame/Karma non letto*');
            Orion.Print(33, 'Testo ricevuto: ' + text);
        }
    } else {
        Orion.CharPrint(Player.Serial(), 33, '*Fame/Karma non trovati nel journal*');
    }

    Orion.Wait(100);

    var gump1 = Orion.GetGump('last');
    if (gump1 !== null) gump1.Close();
}

function IsBloodOathLocked() {
    return Orion.GetGlobal('BloodOathLock') === 'true' || Orion.BuffExists('Blood Oath');
}

function HandleBloodOath() {
    if (!Orion.BuffExists('Blood Oath')) {
        Orion.SetGlobal('BloodOathLock', 'false');
        return false;
    }

    Orion.SetGlobal('BloodOathLock', 'true');

    Orion.Print(33, 'BLOOD OATH RILEVATO!');
    Orion.CharPrint(Player.Serial(), 33, '*BLOOD OATH RILEVATO!*');

    Orion.WarMode(false);
    Orion.CancelTarget();
    Orion.CancelWaitTarget();

    var lastBeep = 0;
    var lastCast = 0;
    var maxSafetyTime = Orion.Now() + 15000;

    while (!Player.Dead() && Orion.BuffExists('Blood Oath')) {
        Orion.WarMode(false);
        Orion.CancelTarget();
        Orion.CancelWaitTarget();

        if (Orion.Now() - lastBeep > 2500) {
            Orion.PlayWav("C:\\Orion Launcher\\OA\\beep.wav");
            lastBeep = Orion.Now();
        }

        if (Orion.Now() - lastCast >= 180) {
            lastCast = Orion.Now();

            Orion.ClearJournal();
            Orion.Cast('209'); // Remove Curse

            if (Orion.WaitForTarget(3000)) {
                Orion.TargetObject('self');
                Orion.Wait(200);
            } else {
                Orion.CancelTarget();
                Orion.CancelWaitTarget();
                Orion.Wait(80);
            }

            if (
                Orion.InJournal('fizzles') ||
                Orion.InJournal('You are frozen') ||
                Orion.InJournal('You cannot move') ||
                Orion.InJournal('You must wait') ||
                Orion.InJournal('not yet recovered')
            ) {
                Orion.Wait(80);
            }
        }

        if (Orion.Now() > maxSafetyTime) {
            maxSafetyTime = Orion.Now() + 15000;
        }

        Orion.Wait(40);
    }

    Orion.CancelTarget();
    Orion.CancelWaitTarget();
    Orion.SetGlobal('BloodOathLock', 'false');

    if (!Player.Dead()) {
        Orion.CharPrint(Player.Serial(), 65, '*BLOOD OATH RIMOSSO*');
        Orion.Print(65, 'BLOOD OATH RIMOSSO');
    }

    return true;
}

function AutoCleansePoison() {
    var lastCast = 0;
    var lastCombat = 0;

    Orion.Print(65, 'AutoCleansePoison AVVIATO');

    while (!Player.Dead()) {
        if (Orion.GetGlobal('StopAllScripts') === 'true') return;

        var now = Orion.Now();

        var inCombat = false;

        if (Player.WarMode()) {
            inCombat = true;
            lastCombat = now;
        }

        var lastAttack = Orion.ClientLastAttack();

        if (lastAttack && lastAttack !== '' && lastAttack !== '0x000') {
            var mob = Orion.FindObject(lastAttack);

            if (mob && Orion.ObjectExists(lastAttack) && mob.Hits() > 0 && mob.Distance() <= 12) {
                inCombat = true;
                lastCombat = now;
            }
        }

        var enemies = Orion.FindType(
            'any',
            'any',
            'ground',
            'mobile|live|near|inlos|ignoreself|ignorefriends',
            12,
            'gray|criminal|red|enemy|orange'
        );

        if (enemies && enemies.length > 0) {
            inCombat = true;
            lastCombat = now;
        }

        if (inCombat || now - lastCombat < 6000) {
            Orion.Wait(250);
            continue;
        }

        if (!Orion.BuffExists('Poison')) {
            Orion.Wait(250);
            continue;
        }

        if (Player.Mana() < 10) {
            Orion.Wait(500);
            continue;
        }

        if (now - lastCast < 3000) {
            Orion.Wait(250);
            continue;
        }

        lastCast = now;

        Orion.CharPrint(Player.Serial(), 65, '*CLEANSE POISON*');

        Orion.WarMode(false);
        Orion.CancelTarget();
        Orion.CancelWaitTarget();
        Orion.ClearJournal();

        Orion.Cast('Cleanse by Fire');

        if (Orion.WaitForTarget(2000)) {
            Orion.TargetObject(Player.Serial());
            Orion.Wait(700);
        } else {
            Orion.CancelTarget();
            Orion.CancelWaitTarget();
            Orion.Wait(200);
        }

        Orion.Wait(250);
    }
}

// =====================================================
// DOOM WATCHER - 
// =====================================================

// Struttura per tracciare i tempi e i drop già contati
if (!Shared.GetVar('doom_known_artifacts')) Shared.AddVar('doom_known_artifacts', '');
if (!Shared.GetVar('doom_total_seconds')) Shared.AddVar('doom_total_seconds', 0);
if (!Shared.GetVar('doom_last_room6_time')) Shared.AddVar('doom_last_room6_time', 0);



function DoomWatcherGUI() {
    var g = Orion.CreateCustomGump(101200); 
    g.Clear();
    g.SetCallback('DoomWatcherOnClick');

    var offsetX = typeof GetCompagnoneGuiX === 'function' ? GetCompagnoneGuiX() + 450 : 330;
    var offsetY = typeof GetCompagnoneGuiY === 'function' ? GetCompagnoneGuiY() - 130 : 100;

    // FORZATURA INTERA: 7 e 5 bloccano la pietra ed eliminano lo sfondo nero tagliato sotto
    DrawPanel(g, offsetX, offsetY, 7, 5);

    var hueLabel = typeof HUE_STATUS_LABEL !== 'undefined' ? HUE_STATUS_LABEL : 1152;
    g.AddText(offsetX + 55, offsetY + 12, hueLabel, '*DOOM WATCHER*');

    // Forzato il posizionamento della X nell'angolo del pannello largo
    g.AddButton(2000, offsetX + 195, offsetY + 14, 0xA94, 0xA94, 0xA95, '0');
    g.AddTooltip('Chiudi Watcher');

    var counter = Number(Shared.GetVar('doom_watcher_counter')) || 0;
    var dropTotal = Number(Shared.GetVar('doom_watcher_drop_total')) || 0;
    
    // Testo dei giri medi in CAPSLOCK
    var giriPerDropStr = 'N/D';
    if (dropTotal > 0) {
        giriPerDropStr = (Math.round((counter / dropTotal) * 10) / 10) + ' GIRI';
    }

    // Testo del tempo in CAPSLOCK
    var totalSeconds = Number(Shared.GetVar('doom_total_seconds')) || 0;
    var mediaTempoStr = 'N/D';
    if (counter > 0 && totalSeconds > 0) {
        var avgSecondsTotal = Math.round(totalSeconds / counter);
        var min = Math.floor(avgSecondsTotal / 60);
        var sec = avgSecondsTotal % 60;
        mediaTempoStr = min + 'M ' + (sec < 10 ? '0' : '') + sec + 'S';
    }

    // Etichette in CAPSLOCK con allineamento corretto dentro il pannello largo
    var textY = offsetY + 45;
    g.AddText(offsetX + 30, textY, 1271, 'GIRI COMPLETI: ' + counter); textY += 20;
    g.AddText(offsetX + 30, textY, 1271, 'DROP TOTALI: ' + dropTotal); textY += 20;
    g.AddText(offsetX + 30, textY, 1271, 'MEDIA GIRI / DROP: ' + giriPerDropStr); textY += 20;
    g.AddText(offsetX + 30, textY, 1271, 'MEDIA TEMPO / GIRO: ' + mediaTempoStr);

    // Centraggio matematico del bottone RESET STATS (grafica 23, font 12)
    var bottoneLarghezza = 142; 
    var pannelloLarghezzaPixel = 240; 
    var centroX = Math.round((pannelloLarghezzaPixel - bottoneLarghezza) / 2);

    AddBigButton(g, 9001, offsetX + centroX, textY + 22, '23', 33, 'RESET STATS', 'Resetta contatori e tempi Doom', 12);

    g.SetNoClose(true);
    g.Update();
}


function DoomWatcherOnClick() {
    var buttonID = CustomGumpResponse.ReturnCode();

    if (buttonID === 2000) { 
        Shared.AddVar('doom_watcher_active', false); 
        if (Orion.ScriptRunning('MonitorDoomDrops')) {
            Orion.Terminate('MonitorDoomDrops');
        }
        var gClose = Orion.CreateCustomGump(101200);
        gClose.Close();
        return;
    }

    if (buttonID === 9001) {
        Shared.AddVar('doom_watcher_active', true);
        Shared.AddVar('doom_watcher_counter', 0);
        Shared.AddVar('doom_watcher_drop_total', 0);
        Shared.AddVar('doom_total_seconds', 0);
        Shared.AddVar('doom_last_room6_time', new Date().getTime());
        
        // Riavvia il monitor pulito
        if (Orion.ScriptRunning('MonitorDoomDrops')) {
            Orion.Terminate('MonitorDoomDrops');
            Orion.Wait(100);
        }
        Orion.Exec('MonitorDoomDrops');
        
        Orion.CharPrint(Player.Serial(), 65, 'Doom Watcher resettato!');
    }

    DoomWatcherGUI();
}

function StartDoomWatcher() {
    Shared.AddVar('doom_watcher_active', true);
    
    if (Number(Shared.GetVar('doom_last_room6_time')) === 0) {
        Shared.AddVar('doom_last_room6_time', new Date().getTime());
    }

    // Avvia il monitor con la nuova logica di snapshot automatico
    if (!Orion.ScriptRunning('MonitorDoomDrops')) {
        Orion.Exec('MonitorDoomDrops');
    }
    
    DoomWatcherGUI();
}



