function UpsertRepairItem(graphic, name, tool) {
    graphic = NormalizeRepairGraphicLocal(graphic);
    var g = graphic.toLowerCase();

    for (var i = itemArr.length - 3; i >= 0; i -= 3) {
        if (String(itemArr[i]).toLowerCase() === g) {
            itemArr[i] = graphic;
            itemArr[i + 1] = name;
            itemArr[i + 2] = tool;
            return;
        }
    }

    itemArr.push(graphic, name, tool);
}

function MergeRuntimeRepairOverrides() {
    var data = Shared.GetVar('repairbench_runtime_overrides');

    if (!data) {
        return;
    }

    var rows = String(data).split('\n');

    for (var i = 0; i < rows.length; i++) {
        if (!rows[i]) {
            continue;
        }

        var parts = rows[i].split('§');

        if (parts.length < 3) {
            continue;
        }

        UpsertRepairItem(parts[0], parts[1], parts[2]);
    }
}

function NormalizeRepairGraphicLocal(graphic) {
    var g = String(graphic);

    if (g.indexOf('0x') !== 0 && g.indexOf('0X') !== 0) {
        g = '0x' + g;
    }

    return g.toUpperCase().replace('0X', '0x');
}

// =====================================================
// REPAIR BENCH - CUSTOM ITEMS SYSTEM
// =====================================================

var customRepairArr = [
    '0x1B76','Heater Shield Of The Umbrascale','blacksmith'
];

//var customRepairMerged = false;

function MergeCustomRepairArr() {
    if (!customRepairArr || !customRepairArr.length) {
        return;
    }

    for (var i = 0; i < customRepairArr.length; i += 3) {
        var graphic = String(customRepairArr[i]).toLowerCase();
        var name = customRepairArr[i + 1];
        var tool = customRepairArr[i + 2];

        var found = false;

        for (var j = itemArr.length - 3; j >= 0; j -= 3) {
            if (String(itemArr[j]).toLowerCase() === graphic) {
                itemArr[j] = customRepairArr[i];
                itemArr[j + 1] = name;
                itemArr[j + 2] = tool;
                found = true;
                break;
            }
        }

        if (!found) {
            itemArr.push(customRepairArr[i], name, tool);
        }
    }
}

