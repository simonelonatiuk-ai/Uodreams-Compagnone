function RepairGear() {
    MergeCustomRepairArr();
    MergeRuntimeRepairOverrides();

    var minDura = 220;
    var backpack = Orion.FindObject("backpack");
    
    if (!backpack) {
        Orion.Print("Errore: Zaino non trovato!");
        return;
    }

    // Trova la repair bench a terra (raggio 3 caselle)
    var repairBench = Orion.FindType("0xA278|0xA277|0xA27F|0xA27E", "0x0", "ground", 3);
    if (!repairBench.length) {
        Orion.Print("Errore: Repair bench non trovata vicino a te!");
        return;
    }

    Orion.Print("Interazione con la repair bench...");
    Orion.UseObject(repairBench[0]);

    // Attendi l'apertura del gump di riparazione
    if (!Orion.WaitForGump(2000)) {
        Orion.Print("Errore: Gump di riparazione non apparso.");
        return;
    }

    // Trova tutti gli oggetti nello zaino
    var items = Orion.FindType("any", "any", backpack.Serial());
    if (!items.length) {
        Orion.Print("Zaino vuoto.");
        return;
    }

    for (var i = 0; i < items.length; i++) {
        var item = Orion.FindObject(items[i]);
        if (!item) continue;

        var properties = item.Properties();
        var currentGraphic = item.Graphic().toLowerCase();
        var objInd = -1;

for (var j = itemArr.length - 3; j >= 0; j -= 3) {
    if (itemArr[j].toLowerCase() === currentGraphic) {
        objInd = j;
        break;
    }
}

        // 1. Salta se l'oggetto è Imbued
        if (Orion.Contains(properties, "Imbued")) {
            continue;
        }

        // 2. Controllo Durabilità con Regex specifica (Cerca il formato "X / Y")
        // Questo evita di leggere "Durability 70%" dei materiali speciali
        var duraMatch = properties.match(/Durability\s+(\d+)\s+\/\s+(\d+)/i);

        if (duraMatch && objInd >= 0) {
            var currentDura = Number(duraMatch[1]);
            var maxDura = Number(duraMatch[2]);

            // Ripara se sotto la soglia E se non è già al massimo
            if (currentDura < minDura && currentDura < maxDura) {
                Orion.Print("Riparazione: " + item.Name() + " [" + currentDura + "/" + maxDura + "]");

                var repairType = itemArr[objInd + 2];
                var gumpHook = 0;

                switch (repairType) {
                    case "blacksmith": gumpHook = 10; break;
                    case "tailor":     gumpHook = 11; break;
                    case "tinker":     gumpHook = 12; break;
                    case "carpenter":  gumpHook = 13; break;
                    default: continue;
                }

                var gump = Orion.GetGump("last");
                if (gump) {
                    gump.Select(Orion.CreateGumpHook(gumpHook));
                    
                    if (Orion.WaitForTarget(2000)) {
                        Orion.TargetObject(item.Serial());
                        Orion.Wait(600); // Pausa per evitare lag/blocchi
                    }
                }
            }
        }
    }

    Orion.Print("Riparazioni completate!");
}

